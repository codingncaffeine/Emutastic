<Window x:Class="Emutastic.Views.GameDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Width="520" Height="740"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <DropShadowEffect x:Key="CardShadow"
                          BlurRadius="40"
                          ShadowDepth="0"
                          Opacity="0.8"
                          Color="{StaticResource ShadowColor}"/>
    </Window.Resources>

    <!-- Dark overlay background -->
    <Grid>
        <Rectangle Fill="#99000000"
                   MouseLeftButtonDown="Overlay_Click"/>

        <!-- Modal card -->
        <Border x:Name="ModalCard"
                Background="{DynamicResource BgSecondaryBrush}"
                BorderBrush="{DynamicResource BorderNormalBrush}"
                BorderThickness="1"
                CornerRadius="14"
                Width="460"
                Effect="{StaticResource CardShadow}"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="345"/>
                    <!-- Art: 460×345 = 4:3 -->
                    <RowDefinition Height="*"/>
                    <!-- Info -->
                </Grid.RowDefinitions>

                <!-- Art area -->
                <Border Grid.Row="0"
                        CornerRadius="14,14,0,0"
                        ClipToBounds="True">
                    <Grid>
                        <!-- Background color from game -->
                        <Border x:Name="ArtBackground">
                            <Border.Background>
                                <SolidColorBrush x:Name="ArtBgBrush" Color="{StaticResource BgTertiaryColor}"/>
                            </Border.Background>
                        </Border>

                        <!-- Video rendered via LibVLC callback → WriteableBitmap -->
                        <Image x:Name="VideoImage"
                               Stretch="UniformToFill"
                               RenderOptions.BitmapScalingMode="LowQuality"
                               Visibility="Collapsed"/>

                        <!-- Cover art / screenshot — on top, stays visible until video is ready -->
                        <Image x:Name="HeaderImage"
                               Stretch="UniformToFill"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               Visibility="Collapsed"/>

                        <!-- Gradient overlay -->
                        <Border>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#44FFFFFF" Offset="0"/>
                                    <GradientStop Color="#00FFFFFF" Offset="0.5"/>
                                    <GradientStop Color="#88000000" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>

                        <!-- Game title as placeholder -->
                        <TextBlock x:Name="ArtPlaceholderText"
                                   FontFamily="{StaticResource PrimaryFont}"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="#AAFFFFFF"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Margin="32"/>

                        <!-- Close button -->
                        <Border Background="#66000000"
                                CornerRadius="12"
                                Width="24" Height="24"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Margin="0,12,12,0"
                                Cursor="Hand"
                                MouseLeftButtonDown="CloseButton_Click">
                            <TextBlock Text="✕"
                                       FontSize="11"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <!-- Favorite badge -->
                        <Border x:Name="FavoriteBadge"
                                Background="#44000000"
                                CornerRadius="12"
                                Width="24" Height="24"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Margin="0,12,42,0"
                                Visibility="Collapsed">
                            <TextBlock Text="♥"
                                       FontSize="11"
                                       Foreground="{DynamicResource FavoriteHeartBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <!-- Console tag -->
                        <Border Background="#88000000"
                                CornerRadius="6"
                                Padding="10,4"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Bottom"
                                Margin="16,0,0,16">
                            <TextBlock x:Name="ConsoleTag"
                                       FontFamily="{StaticResource PrimaryFont}"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="White"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Info area -->
                <StackPanel Grid.Row="1" Margin="24,20,24,24">

                    <!-- Title -->
                    <TextBlock x:Name="GameTitle"
                               FontFamily="{StaticResource PrimaryFont}"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               TextWrapping="Wrap"/>

                    <!-- Metadata pills row -->
                    <WrapPanel x:Name="MetadataPanel" Margin="0,10,0,0"
                               Visibility="Collapsed">
                        <!-- Year pill -->
                        <Border x:Name="YearPill"
                                Background="{DynamicResource BgTertiaryBrush}"
                                CornerRadius="4" Padding="8,3" Margin="0,0,6,6"
                                Visibility="Collapsed">
                            <TextBlock x:Name="GameYear"
                                       FontFamily="{StaticResource PrimaryFont}"
                                       FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </Border>
                        <!-- Developer pill -->
                        <Border x:Name="DeveloperPill"
                                Background="{DynamicResource BgTertiaryBrush}"
                                CornerRadius="4" Padding="8,3" Margin="0,0,6,6"
                                Visibility="Collapsed">
                            <TextBlock x:Name="GameDeveloper"
                                       FontFamily="{StaticResource PrimaryFont}"
                                       FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </Border>
                        <!-- Genre pill -->
                        <Border x:Name="GenrePill"
                                Background="{DynamicResource BgTertiaryBrush}"
                                CornerRadius="4" Padding="8,3" Margin="0,0,6,6"
                                Visibility="Collapsed">
                            <TextBlock x:Name="GameGenre"
                                       FontFamily="{StaticResource PrimaryFont}"
                                       FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
                        </Border>
                    </WrapPanel>

                    <!-- Description -->
                    <TextBlock x:Name="GameDescription"
                               FontFamily="{StaticResource PrimaryFont}"
                               FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               TextWrapping="Wrap"
                               MaxHeight="54"
                               Margin="0,4,0,0"
                               LineHeight="18"
                               Visibility="Collapsed"/>

                    <!-- Stats row -->
                    <Grid Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Background="{DynamicResource BgTertiaryBrush}"
                                CornerRadius="8"
                                Padding="0,12"
                                Margin="0,0,6,0">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock x:Name="StatPlayed"
                                           FontFamily="{StaticResource PrimaryFont}"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Times Played"
                                           FontFamily="{StaticResource PrimaryFont}"
                                           FontSize="10"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           HorizontalAlignment="Center"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1"
                                Background="{DynamicResource BgTertiaryBrush}"
                                CornerRadius="8"
                                Padding="0,12"
                                Margin="0,0,6,0">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock x:Name="StatSaves"
                                           FontFamily="{StaticResource PrimaryFont}"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Save States"
                                           FontFamily="{StaticResource PrimaryFont}"
                                           FontSize="10"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           HorizontalAlignment="Center"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2"
                                Background="{DynamicResource BgTertiaryBrush}"
                                CornerRadius="8"
                                Padding="0,12">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock x:Name="StatLastPlayed"
                                           FontFamily="{StaticResource PrimaryFont}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Last Played"
                                           FontFamily="{StaticResource PrimaryFont}"
                                           FontSize="10"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           HorizontalAlignment="Center"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Action buttons -->
                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
        Content="▶   Play Now"
        Style="{StaticResource PlayButtonStyle}"
        Height="42"
        Margin="0,0,8,0"
        Click="PlayButton_Click"/>
                        <Button Grid.Column="1"
                                Content="♡  Favorite"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Height="42"
                                Margin="0,0,8,0"
                                x:Name="FavoriteButton"
                                Click="FavoriteButton_Click"/>

                        <Button Grid.Column="2"
                                Content="⋯"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Height="42"
                                Width="42"
                                Click="MoreButton_Click"/>
                    </Grid>

                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>