<Window x:Class="Emutastic.Views.EmulatorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize"
        Width="854" Height="520"
        WindowStartupLocation="CenterOwner"
        KeyDown="Window_KeyDown"
        Closing="Window_Closing">

    <Window.Resources>
        <DropShadowEffect x:Key="WindowShadow"
                          BlurRadius="30"
                          ShadowDepth="0"
                          Opacity="0.8"
                          Color="#000000"/>

        <!-- Overlay pill button (Power / Pause / Restart / Save / Cog) -->
        <Style x:Key="OverlayPillBtnStyle" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width"           Value="54"/>
            <Setter Property="Height"          Value="56"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="Transparent" CornerRadius="8" Margin="4,8,4,8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#55FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark ComboBox for the Core Options overlay panel -->
        <ControlTemplate x:Key="OverlayComboToggle" TargetType="ToggleButton">
            <Border x:Name="bd" Background="#27272A" BorderBrush="#44444A" BorderThickness="1" CornerRadius="4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                    </Grid.ColumnDefinitions>
                    <ContentPresenter Grid.Column="0" Margin="8,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    <Path Grid.Column="1" Data="M0,0 L4,5 L8,0" Stroke="#888" StrokeThickness="1.5"
                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="bd" Property="Background" Value="#33333A"/>
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter TargetName="bd" Property="BorderBrush" Value="#E03535"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <ControlTemplate x:Key="OverlayComboTemplate" TargetType="ComboBox">
            <Grid>
                <ToggleButton Template="{StaticResource OverlayComboToggle}"
                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                              Focusable="False"/>
                <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False"
                                  Content="{TemplateBinding SelectionBoxItem}"
                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                  Margin="9,0,24,0" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                <TextBox x:Name="PART_EditableTextBox" Visibility="Hidden" IsReadOnly="True"/>
                <Popup x:Name="Popup" Placement="Bottom"
                       IsOpen="{TemplateBinding IsDropDownOpen}"
                       AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                    <Grid MinWidth="{TemplateBinding ActualWidth}" MaxHeight="180">
                        <Border Background="#1E1E21" BorderBrush="#44444A" BorderThickness="1" CornerRadius="4">
                            <ScrollViewer><ItemsPresenter/></ScrollViewer>
                        </Border>
                    </Grid>
                </Popup>
            </Grid>
        </ControlTemplate>

        <Style x:Key="OverlayComboBox" TargetType="ComboBox">
            <Setter Property="Template"   Value="{StaticResource OverlayComboTemplate}"/>
            <Setter Property="Foreground" Value="#F0F0F0"/>
            <Setter Property="Background" Value="#27272A"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Height"     Value="30"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="#F0F0F0"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Padding"    Value="8,5"/>
                        <Setter Property="FontSize"   Value="11"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#33333A"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#33E03535"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Overlay settings menu item -->
        <Style x:Key="OverlayMenuItemStyle" TargetType="Button">
            <Setter Property="Background"                 Value="Transparent"/>
            <Setter Property="Foreground"                 Value="White"/>
            <Setter Property="BorderThickness"            Value="0"/>
            <Setter Property="HorizontalAlignment"        Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontSize"                   Value="12"/>
            <Setter Property="Padding"                    Value="10,7,10,7"/>
            <Setter Property="Cursor"                     Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="Transparent" CornerRadius="4">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#22FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#44FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="RootBorder" Background="Black"
            BorderBrush="{StaticResource BorderSubtleBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Effect="{StaticResource WindowShadow}"
            MouseMove="RootBorder_MouseMove"
            PreviewMouseLeftButtonDown="RootBorder_PreviewMouseLeftButtonDown">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0"
                  Background="{StaticResource BgSecondaryBrush}"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="GameTitleText"
                           Grid.Column="0"
                           FontFamily="{StaticResource PrimaryFont}"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0"/>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,8,0">
                    <Button x:Name="MinBtn"
                            Width="12" Height="12"
                            Margin="0,0,5,0"
                            Click="MinBtn_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Ellipse Fill="#FEBC2E"/>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button x:Name="MaxBtn"
                            Width="12" Height="12"
                            Margin="0,0,5,0"
                            Click="MaxBtn_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Ellipse Fill="#28C840"/>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button x:Name="CloseBtn"
                            Width="12" Height="12"
                            Click="CloseBtn_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Ellipse Fill="#FF5F57"/>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Game viewport -->
            <Border Grid.Row="1" Background="Black">
                <Grid x:Name="GameViewport">
                    <Image x:Name="GameScreen"
                           Stretch="Uniform"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           RenderOptions.BitmapScalingMode="NearestNeighbor"/>

                    <!-- Vectrex game overlay (transparent PNG layered on top) -->
                    <Image x:Name="VectrexOverlayImage"
                           Stretch="Fill"
                           IsHitTestVisible="False"
                           Visibility="Collapsed"
                           RenderOptions.BitmapScalingMode="HighQuality"/>

                    <!-- Inline load-state picker (shown above HUD, right-aligned) -->
                    <Border x:Name="LoadPickerPanel"
                            Visibility="Collapsed"
                            VerticalAlignment="Bottom"
                            HorizontalAlignment="Right"
                            Margin="0,0,8,8"
                            Background="#E6121214"
                            BorderBrush="{StaticResource BorderSubtleBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            MinWidth="260"
                            MaxWidth="340">
                        <StackPanel Margin="8,8,8,8">
                            <TextBlock Text="Load Save State"
                                       FontFamily="{StaticResource PrimaryFont}"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,0,0,6"/>
                            <StackPanel x:Name="LoadPickerItems"/>
                            <TextBlock x:Name="LoadPickerEmpty"
                                       Text="No save states yet"
                                       FontFamily="{StaticResource PrimaryFont}"
                                       FontSize="11"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       Visibility="Collapsed"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Core options panel (shown from overlay cog → Core Options…) -->
                    <Border x:Name="CoreOptionsPanel"
                            Visibility="Collapsed"
                            VerticalAlignment="Bottom"
                            HorizontalAlignment="Left"
                            Margin="8,0,0,8"
                            Background="#EE121214"
                            BorderBrush="#44FFFFFF"
                            BorderThickness="1"
                            CornerRadius="6"
                            MinWidth="300"
                            MaxWidth="420">
                        <StackPanel Margin="10,10,10,10">
                            <Grid Margin="0,0,0,8">
                                <TextBlock Text="Core Options"
                                           FontFamily="{StaticResource PrimaryFont}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="White"
                                           VerticalAlignment="Center"/>
                                <Button x:Name="CoreOptionsDoneBtn"
                                        Content="Done"
                                        HorizontalAlignment="Right"
                                        FontSize="10"
                                        Padding="10,4"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Click="CoreOptionsDone_Click"/>
                            </Grid>
                            <ScrollViewer MaxHeight="360"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <StackPanel x:Name="CoreOptionRows" Margin="0,0,4,0"/>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>

                    <!-- In-game hover overlay -->
                    <StackPanel x:Name="OverlayHud"
                                Visibility="Collapsed"
                                Opacity="0"
                                VerticalAlignment="Bottom"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,20"
                                Panel.ZIndex="10">

                        <!-- Settings menu (stacks above pill) -->
                        <Border x:Name="OverlayMenu"
                                Visibility="Collapsed"
                                Background="#EE0F0F11"
                                BorderBrush="#44FFFFFF"
                                BorderThickness="1"
                                CornerRadius="8"
                                MinWidth="210"
                                Margin="0,0,0,6"
                                HorizontalAlignment="Center">
                            <StackPanel Margin="4,4,4,4">
                                <Button x:Name="OverlayEditControlsBtn"
                                        Content="Edit Game Controls…"
                                        Style="{StaticResource OverlayMenuItemStyle}"
                                        Click="OverlayEditControls_Click"/>
<Button x:Name="OverlayFlipBtn"
                                        Content="Flip Display"
                                        Style="{StaticResource OverlayMenuItemStyle}"
                                        Click="OverlayFlip_Click"/>
                                <Button x:Name="OverlayToggleBtn"
                                        Content="Overlay: On"
                                        Visibility="Collapsed"
                                        Style="{StaticResource OverlayMenuItemStyle}"
                                        Click="OverlayToggle_Click"/>
                                <Button x:Name="OverlayScreenLayoutBtn"
                                        Visibility="Collapsed"
                                        Style="{StaticResource OverlayMenuItemStyle}"
                                        Click="OverlayScreenLayout_Click"/>
                                <Rectangle Height="1" Fill="#33FFFFFF" Margin="6,2,6,2"/>
                                <TextBlock x:Name="OverlayCoreLabel"
                                           Foreground="#99FFFFFF"
                                           FontSize="10"
                                           Margin="10,0,10,4"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </Border>

                        <!-- Save / Load menu (stacks above pill, toggled by Save pill button) -->
                        <Border x:Name="SaveMenu"
                                Visibility="Collapsed"
                                Background="#EE0F0F11"
                                BorderBrush="#44FFFFFF"
                                BorderThickness="1"
                                CornerRadius="8"
                                Margin="0,0,0,6"
                                HorizontalAlignment="Center"
                                MouseLeave="SaveMenu_MouseLeave">
                            <StackPanel Orientation="Horizontal">
                                <!-- Left: Save / Load actions -->
                                <StackPanel MinWidth="180">
                                    <Button Content="Save State"
                                            Style="{StaticResource OverlayMenuItemStyle}"
                                            MouseEnter="SaveMenuItem_MouseEnter"
                                            Click="OverlaySaveDirect_Click"/>
                                    <Rectangle Height="1" Fill="#33FFFFFF" Margin="6,2,6,2"/>
                                    <Button x:Name="LoadStateHoverBtn"
                                            Style="{StaticResource OverlayMenuItemStyle}"
                                            MouseEnter="LoadStateHover_Enter">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Load State" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="›" FontSize="16"
                                                       VerticalAlignment="Center" Margin="12,0,0,0"
                                                       Foreground="#88FFFFFF"/>
                                        </Grid>
                                    </Button>
                                </StackPanel>
                                <!-- Right: slot list — slides in on hover over Load State -->
                                <Border x:Name="LoadSlotSubmenu"
                                        ClipToBounds="True"
                                        MaxWidth="0"
                                        BorderBrush="#33FFFFFF"
                                        BorderThickness="1,0,0,0">
                                    <StackPanel x:Name="OverlayLoadSlotItems"
                                                Margin="4,4,4,4"
                                                Width="220"/>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Pill -->
                        <Border Background="#CC1C1C1E"
                                CornerRadius="28"
                                Padding="6,0"
                                HorizontalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Height="56">
                                <Button x:Name="OverlayPowerBtn"
                                        Style="{StaticResource OverlayPillBtnStyle}"
                                        ToolTip="Close Game"
                                        Click="OverlayPower_Click">
                                    <Image Source="/Assets/buttons/powerbutton.png"
                                           Width="45" Height="45"
                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Button>
                                <Button x:Name="OverlayPauseBtn"
                                        Style="{StaticResource OverlayPillBtnStyle}"
                                        ToolTip="Pause / Resume"
                                        Click="OverlayPause_Click">
                                    <md:PackIcon x:Name="OverlayPauseIcon" Kind="Pause" Width="22" Height="22" Foreground="White"/>
                                </Button>
                                <Button x:Name="OverlaySaveBtn"
                                        Style="{StaticResource OverlayPillBtnStyle}"
                                        ToolTip="Save State"
                                        Click="OverlaySave_Click">
                                    <md:PackIcon Kind="ContentSave" Width="22" Height="22" Foreground="White"/>
                                </Button>
                                <Rectangle Width="1" Fill="#44FFFFFF" Margin="0,14,0,14"/>
                                <Button x:Name="OverlayCogBtn"
                                        Style="{StaticResource OverlayPillBtnStyle}"
                                        ToolTip="Settings"
                                        Click="OverlayCog_Click">
                                    <md:PackIcon Kind="Cog" Width="22" Height="22" Foreground="White"/>
                                </Button>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Achievement toast -->
                    <Border x:Name="AchievementToast"
                            Visibility="Collapsed"
                            Opacity="0"
                            VerticalAlignment="Top"
                            HorizontalAlignment="Center"
                            Margin="0,20,0,0"
                            Background="#DD1A1A2E"
                            BorderBrush="#FFFFD700"
                            BorderThickness="1.5"
                            CornerRadius="10"
                            Padding="18,12"
                            MinWidth="280"
                            MaxWidth="450">
                        <StackPanel>
                            <TextBlock x:Name="AchievementTitle"
                                       FontSize="14" FontWeight="Bold"
                                       Foreground="#FFFFD700"
                                       TextWrapping="Wrap"/>
                            <TextBlock x:Name="AchievementDesc"
                                       FontSize="11.5"
                                       Foreground="#CCFFFFFF"
                                       TextWrapping="Wrap"
                                       Margin="0,3,0,0"/>
                            <TextBlock x:Name="AchievementPoints"
                                       FontSize="10.5"
                                       Foreground="#99FFFFFF"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Status bar -->
            <Border Grid.Row="2"
                    Background="{StaticResource BgSecondaryBrush}"
                    BorderBrush="{StaticResource BorderSubtleBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="12,4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="StatusText"
                               Grid.Column="0"
                               Text="Running"
                               FontFamily="{StaticResource PrimaryFont}"
                               FontSize="11"
                               Foreground="{StaticResource TextMutedBrush}"
                               VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">

                        <Button x:Name="SaveStateBtn"
                                Content="💾  Save State"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Padding="10,4"
                                FontSize="11"
                                Margin="0,0,6,0"
                                Click="SaveStateBtn_Click"/>

                        <Button x:Name="LoadStateBtn"
                                Content="📂  Load State"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Padding="10,4"
                                FontSize="11"
                                Margin="0,0,6,0"
                                Click="LoadStateBtn_Click"/>

                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>