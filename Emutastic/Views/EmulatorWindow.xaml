<Window x:Class="Emutastic.Views.EmulatorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip"
        Width="854" Height="520"
        WindowStartupLocation="CenterOwner"
        KeyDown="Window_KeyDown"
        Closing="Window_Closing">

    <Window.Resources>
        <DropShadowEffect x:Key="WindowShadow"
                          BlurRadius="30"
                          ShadowDepth="0"
                          Opacity="0.8"
                          Color="#000000"/>

        <!-- Overlay pill button (Power / Pause / Restart / Save / Cog) -->
        <Style x:Key="OverlayPillBtnStyle" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width"           Value="54"/>
            <Setter Property="Height"          Value="56"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="Transparent" CornerRadius="8" Margin="4,8,4,8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#55FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Overlay settings menu item -->
        <Style x:Key="OverlayMenuItemStyle" TargetType="Button">
            <Setter Property="Background"                 Value="Transparent"/>
            <Setter Property="Foreground"                 Value="White"/>
            <Setter Property="BorderThickness"            Value="0"/>
            <Setter Property="HorizontalAlignment"        Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontSize"                   Value="12"/>
            <Setter Property="Padding"                    Value="10,7,10,7"/>
            <Setter Property="Cursor"                     Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="Transparent" CornerRadius="4">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#22FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#44FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="Black"
            BorderBrush="{StaticResource BorderSubtleBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Effect="{StaticResource WindowShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0"
                  Background="{StaticResource BgSecondaryBrush}"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="GameTitleText"
                           Grid.Column="0"
                           FontFamily="{StaticResource PrimaryFont}"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0"/>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,8,0">
                    <Button x:Name="MinBtn"
                            Width="12" Height="12"
                            Margin="0,0,5,0"
                            Click="MinBtn_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Ellipse Fill="#FEBC2E"/>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button x:Name="MaxBtn"
                            Width="12" Height="12"
                            Margin="0,0,5,0"
                            Click="MaxBtn_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Ellipse Fill="#28C840"/>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button x:Name="CloseBtn"
                            Width="12" Height="12"
                            Click="CloseBtn_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Ellipse Fill="#FF5F57"/>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Game viewport -->
            <Border Grid.Row="1" Background="Black">
                <Grid x:Name="GameViewport">
                    <Image x:Name="GameScreen"
                           Stretch="Uniform"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           RenderOptions.BitmapScalingMode="NearestNeighbor"/>

                    <!-- Inline load-state picker (shown above HUD, right-aligned) -->
                    <Border x:Name="LoadPickerPanel"
                            Visibility="Collapsed"
                            VerticalAlignment="Bottom"
                            HorizontalAlignment="Right"
                            Margin="0,0,8,8"
                            Background="#E6121214"
                            BorderBrush="{StaticResource BorderSubtleBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            MinWidth="260"
                            MaxWidth="340">
                        <StackPanel Margin="8,8,8,8">
                            <TextBlock Text="Load Save State"
                                       FontFamily="{StaticResource PrimaryFont}"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,0,0,6"/>
                            <StackPanel x:Name="LoadPickerItems"/>
                            <TextBlock x:Name="LoadPickerEmpty"
                                       Text="No save states yet"
                                       FontFamily="{StaticResource PrimaryFont}"
                                       FontSize="11"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       Visibility="Collapsed"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- In-game hover overlay -->
                    <StackPanel x:Name="OverlayHud"
                                Visibility="Collapsed"
                                Opacity="0"
                                VerticalAlignment="Bottom"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,20"
                                Panel.ZIndex="10">

                        <!-- Settings menu (stacks above pill) -->
                        <Border x:Name="OverlayMenu"
                                Visibility="Collapsed"
                                Background="#EE0F0F11"
                                BorderBrush="#44FFFFFF"
                                BorderThickness="1"
                                CornerRadius="8"
                                MinWidth="210"
                                Margin="0,0,0,6"
                                HorizontalAlignment="Center">
                            <StackPanel Margin="4,4,4,4">
                                <Button x:Name="OverlayEditControlsBtn"
                                        Content="Edit Game Controls…"
                                        Style="{StaticResource OverlayMenuItemStyle}"
                                        Click="OverlayEditControls_Click"/>
                                <Rectangle Height="1" Fill="#33FFFFFF" Margin="6,2,6,2"/>
                                <TextBlock x:Name="OverlayCoreLabel"
                                           Foreground="#99FFFFFF"
                                           FontSize="10"
                                           Margin="10,0,10,4"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </Border>

                        <!-- Pill -->
                        <Border Background="#CC1C1C1E"
                                CornerRadius="28"
                                Padding="6,0"
                                HorizontalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Height="56">
                                <Button x:Name="OverlayPowerBtn"
                                        Style="{StaticResource OverlayPillBtnStyle}"
                                        ToolTip="Close Game"
                                        Click="OverlayPower_Click">
                                    <Image Source="/Assets/buttons/powerbutton.png"
                                           Width="30" Height="30"
                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Button>
                                <Button x:Name="OverlayPauseBtn"
                                        Style="{StaticResource OverlayPillBtnStyle}"
                                        ToolTip="Pause / Resume"
                                        Click="OverlayPause_Click">
                                    <md:PackIcon x:Name="OverlayPauseIcon" Kind="Pause" Width="22" Height="22" Foreground="White"/>
                                </Button>
                                <Rectangle Width="1" Fill="#44FFFFFF" Margin="0,14,0,14"/>
                                <Button x:Name="OverlayRestartBtn"
                                        Style="{StaticResource OverlayPillBtnStyle}"
                                        ToolTip="Restart"
                                        Click="OverlayRestart_Click">
                                    <md:PackIcon Kind="Replay" Width="22" Height="22" Foreground="White"/>
                                </Button>
                                <Button x:Name="OverlaySaveBtn"
                                        Style="{StaticResource OverlayPillBtnStyle}"
                                        ToolTip="Save State"
                                        Click="OverlaySave_Click">
                                    <md:PackIcon Kind="ContentSave" Width="22" Height="22" Foreground="White"/>
                                </Button>
                                <Rectangle Width="1" Fill="#44FFFFFF" Margin="0,14,0,14"/>
                                <Button x:Name="OverlayCogBtn"
                                        Style="{StaticResource OverlayPillBtnStyle}"
                                        ToolTip="Settings"
                                        Click="OverlayCog_Click">
                                    <md:PackIcon Kind="Cog" Width="22" Height="22" Foreground="White"/>
                                </Button>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Status bar -->
            <Border Grid.Row="2"
                    Background="{StaticResource BgSecondaryBrush}"
                    BorderBrush="{StaticResource BorderSubtleBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="12,4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="StatusText"
                               Grid.Column="0"
                               Text="Running"
                               FontFamily="{StaticResource PrimaryFont}"
                               FontSize="11"
                               Foreground="{StaticResource TextMutedBrush}"
                               VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">

                        <Button x:Name="SaveStateBtn"
                                Content="💾  Save State"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Padding="10,4"
                                FontSize="11"
                                Margin="0,0,6,0"
                                Click="SaveStateBtn_Click"/>

                        <Button x:Name="LoadStateBtn"
                                Content="📂  Load State"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Padding="10,4"
                                FontSize="11"
                                Margin="0,0,6,0"
                                Click="LoadStateBtn_Click"/>

                        <Button x:Name="ResetBtn"
                                Content="↺  Reset"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Padding="10,4"
                                FontSize="11"
                                Click="ResetBtn_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>