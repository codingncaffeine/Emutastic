<Window x:Class="Emutastic.Views.PreferencesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Preferences"
        Height="700" Width="1100"
        MinHeight="520" MinWidth="820"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Themes/DarkTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- ── ComboBox full dark template ── -->
            <ControlTemplate x:Key="DarkComboToggle" TargetType="ToggleButton">
                <Border x:Name="bd"
                        Background="{StaticResource BgTertiaryBrush}"
                        BorderBrush="{StaticResource BorderNormalBrush}"
                        BorderThickness="1"
                        CornerRadius="6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                        </Grid.ColumnDefinitions>
                        <ContentPresenter Grid.Column="0"
                                          Margin="10,0,0,0"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Left"/>
                        <Path Grid.Column="1"
                              x:Name="arrow"
                              Data="M0,0 L4,5 L8,0"
                              Stroke="{StaticResource TextSecondaryBrush}"
                              StrokeThickness="1.5"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"/>
                    </Grid>
                </Border>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource BorderNormalBrush}"/>
                        <Setter TargetName="bd" Property="Background" Value="{StaticResource BgQuaternaryBrush}"/>
                    </Trigger>
                    <Trigger Property="IsChecked" Value="True">
                        <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>

            <ControlTemplate x:Key="DarkComboTemplate" TargetType="ComboBox">
                <Grid>
                    <ToggleButton Template="{StaticResource DarkComboToggle}"
                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                  Focusable="False"/>
                    <ContentPresenter x:Name="ContentSite"
                                      IsHitTestVisible="False"
                                      Content="{TemplateBinding SelectionBoxItem}"
                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                      ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                      Margin="11,0,28,0"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Left"/>
                    <TextBox x:Name="PART_EditableTextBox"
                             Visibility="Hidden"
                             IsReadOnly="{TemplateBinding IsReadOnly}"/>
                    <Popup x:Name="Popup"
                           Placement="Bottom"
                           IsOpen="{TemplateBinding IsDropDownOpen}"
                           AllowsTransparency="True"
                           Focusable="False"
                           PopupAnimation="Slide">
                        <Grid x:Name="DropDown"
                              SnapsToDevicePixels="True"
                              MinWidth="{TemplateBinding ActualWidth}"
                              MaxHeight="{TemplateBinding MaxDropDownHeight}">
                            <Border x:Name="DropDownBorder"
                                    Background="{StaticResource BgTertiaryBrush}"
                                    BorderBrush="{StaticResource BorderNormalBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Margin="0,2,0,0">
                                <ScrollViewer Margin="4,4,4,4"
                                              SnapsToDevicePixels="True">
                                    <StackPanel IsItemsHost="True"
                                                KeyboardNavigation.DirectionalNavigation="Contained"/>
                                </ScrollViewer>
                            </Border>
                        </Grid>
                    </Popup>
                </Grid>
            </ControlTemplate>

            <Style x:Key="DarkComboBoxItem" TargetType="ComboBoxItem">
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Padding"    Value="8,5"/>
                <Setter Property="FontSize"   Value="13"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBoxItem">
                            <Border x:Name="bd"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="4"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{StaticResource BgQuaternaryBrush}"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="PrefComboBox" TargetType="ComboBox">
                <Setter Property="Foreground"           Value="{StaticResource TextPrimaryBrush}"/>
                <Setter Property="Background"           Value="{StaticResource BgTertiaryBrush}"/>
                <Setter Property="BorderBrush"          Value="{StaticResource BorderNormalBrush}"/>
                <Setter Property="BorderThickness"      Value="1"/>
                <Setter Property="FontSize"             Value="13"/>
                <Setter Property="Height"               Value="32"/>
                <Setter Property="Template"             Value="{StaticResource DarkComboTemplate}"/>
                <Setter Property="ItemContainerStyle"   Value="{StaticResource DarkComboBoxItem}"/>
            </Style>

            <!-- Section label above combos -->
            <Style x:Key="PrefLabel" TargetType="TextBlock">
                <Setter Property="Foreground"  Value="{StaticResource TextSecondaryBrush}"/>
                <Setter Property="FontSize"    Value="11"/>
                <Setter Property="FontWeight"  Value="SemiBold"/>
                <Setter Property="Margin"      Value="0,10,0,4"/>
            </Style>

            <!-- Group header inside scrollable list -->
            <Style x:Key="GroupHeader" TargetType="TextBlock">
                <Setter Property="Foreground"  Value="{StaticResource TextSecondaryBrush}"/>
                <Setter Property="FontSize"    Value="10"/>
                <Setter Property="FontWeight"  Value="SemiBold"/>
                <Setter Property="Margin"      Value="0,12,0,4"/>
            </Style>

            <!-- Charcoal Save button -->
            <Style x:Key="ActionBtn" TargetType="Button">
                <Setter Property="Background"      Value="#3A3A3C"/>
                <Setter Property="Foreground"      Value="{StaticResource TextPrimaryBrush}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding"         Value="18,8"/>
                <Setter Property="FontSize"        Value="13"/>
                <Setter Property="FontWeight"      Value="SemiBold"/>
                <Setter Property="Cursor"          Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#4A4A4E"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Secondary button -->
            <Style x:Key="SecondaryBtn" TargetType="Button">
                <Setter Property="Background"      Value="{StaticResource BgQuaternaryBrush}"/>
                <Setter Property="Foreground"      Value="{StaticResource TextPrimaryBrush}"/>
                <Setter Property="BorderBrush"     Value="{StaticResource BorderNormalBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding"         Value="14,8"/>
                <Setter Property="FontSize"        Value="13"/>
                <Setter Property="Cursor"          Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource BgTertiaryBrush}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Accent (red) button -->
            <Style x:Key="AccentButton" TargetType="Button">
                <Setter Property="Background"      Value="#E03535"/>
                <Setter Property="Foreground"      Value="White"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding"         Value="18,8"/>
                <Setter Property="FontSize"        Value="13"/>
                <Setter Property="FontWeight"      Value="SemiBold"/>
                <Setter Property="Cursor"          Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#C02020"/>
                    </Trigger>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter Property="Background" Value="#6B2020"/>
                        <Setter Property="Foreground" Value="#88FFFFFF"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Small outline button (for per-row download) -->
            <Style x:Key="SmallOutlineButton" TargetType="Button">
                <Setter Property="Background"      Value="Transparent"/>
                <Setter Property="Foreground"      Value="{StaticResource TextPrimaryBrush}"/>
                <Setter Property="BorderBrush"     Value="{StaticResource BorderNormalBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding"         Value="10,4"/>
                <Setter Property="FontSize"        Value="11"/>
                <Setter Property="Cursor"          Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource BgTertiaryBrush}"/>
                    </Trigger>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Toggle switch (pill-style) -->
            <Style x:Key="ToggleSwitch" TargetType="ToggleButton">
                <Setter Property="Width"  Value="44"/>
                <Setter Property="Height" Value="24"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ToggleButton">
                            <Grid>
                                <Border x:Name="track"
                                        Background="#3A3A3E"
                                        CornerRadius="12"/>
                                <Border x:Name="thumb"
                                        Width="18" Height="18"
                                        CornerRadius="9"
                                        Background="White"
                                        HorizontalAlignment="Left"
                                        Margin="3,0,0,0"
                                        VerticalAlignment="Center"/>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="track" Property="Background" Value="{StaticResource AccentBrush}"/>
                                    <Setter TargetName="thumb" Property="HorizontalAlignment" Value="Right"/>
                                    <Setter TargetName="thumb" Property="Margin" Value="0,0,3,0"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="track" Property="Opacity" Value="0.85"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- macOS-style window button -->
            <Style x:Key="WinBtn" TargetType="Button">
                <Setter Property="Width"  Value="13"/>
                <Setter Property="Height" Value="13"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Ellipse x:Name="circle" Fill="{TemplateBinding Background}"/>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="circle" Property="Opacity" Value="0.8"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Nav tab RadioButton style -->
            <Style x:Key="NavBtn" TargetType="RadioButton">
                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="16,0"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Height" Value="46"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="RadioButton">
                            <!-- Outer grid holds the full 46px hit area -->
                            <Grid>
                                <!-- Pill: vertically centred, slightly shorter than the bar -->
                                <Border x:Name="bd" Background="Transparent" CornerRadius="8"
                                        Padding="{TemplateBinding Padding}"
                                        VerticalAlignment="Center" Height="32">
                                    <ContentPresenter VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#2E2E32"/>
                                </Trigger>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                    <Setter TargetName="bd" Property="Background" Value="#3A3A3E"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Provider pill toggle (ScreenScraper / EmuMovies selector) -->
            <Style x:Key="ProviderPill" TargetType="RadioButton">
                <Setter Property="Foreground"   Value="{StaticResource TextSecondaryBrush}"/>
                <Setter Property="Background"   Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding"      Value="16,6"/>
                <Setter Property="FontSize"     Value="12"/>
                <Setter Property="FontWeight"   Value="SemiBold"/>
                <Setter Property="Cursor"       Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="RadioButton">
                            <Border x:Name="bd" Background="Transparent" CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#3A3A3E"/>
                                </Trigger>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                    <Setter TargetName="bd" Property="Background" Value="#4A4A4F"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Dark-themed TextBox -->
            <Style x:Key="DarkTextBox" TargetType="TextBox">
                <Setter Property="Background"   Value="{StaticResource BgTertiaryBrush}"/>
                <Setter Property="Foreground"   Value="{StaticResource TextPrimaryBrush}"/>
                <Setter Property="BorderBrush"  Value="{StaticResource BorderNormalBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding"      Value="10,8"/>
                <Setter Property="FontSize"     Value="13"/>
                <Setter Property="CaretBrush"   Value="{StaticResource TextPrimaryBrush}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TextBox">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsFocused" Value="True">
                                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Dark-themed PasswordBox -->
            <Style x:Key="DarkPasswordBox" TargetType="PasswordBox">
                <Setter Property="Background"   Value="{StaticResource BgTertiaryBrush}"/>
                <Setter Property="Foreground"   Value="{StaticResource TextPrimaryBrush}"/>
                <Setter Property="BorderBrush"  Value="{StaticResource BorderNormalBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding"      Value="10,8"/>
                <Setter Property="FontSize"     Value="13"/>
                <Setter Property="CaretBrush"   Value="{StaticResource TextPrimaryBrush}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="PasswordBox">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsFocused" Value="True">
                                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

        </ResourceDictionary>
    </Window.Resources>

    <!-- Outer border gives the drop shadow + rounded corners -->
    <Border x:Name="OuterBorder"
            Margin="10"
            CornerRadius="10"
            Background="{StaticResource BgPrimaryBrush}"
            BorderBrush="{StaticResource BorderNormalBrush}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.6" Color="#000000"/>
        </Border.Effect>

        <Grid x:Name="RootGrid">
            <Grid.RowDefinitions>
                <RowDefinition Height="38"/>
                <RowDefinition Height="46"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ═══ TITLE BAR ══════════════════════════════════════════════ -->
            <Grid x:Name="CustomTitleBar"
                  Grid.Row="0"
                  Background="{StaticResource BgSecondaryBrush}"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Preferences"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           VerticalAlignment="Center"
                           Margin="14,0,0,0"/>

                <Rectangle Grid.Column="1" Fill="Transparent"/>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,12,0">
                    <Button Background="#FEBC2E" Style="{StaticResource WinBtn}"
                            Margin="0,0,6,0" ToolTip="Minimize"
                            Click="MinimizeButton_Click"/>
                    <Button Background="#28C840" Style="{StaticResource WinBtn}"
                            Margin="0,0,6,0" ToolTip="Maximize"
                            Click="MaximizeButton_Click"/>
                    <Button Background="#FF5F57" Style="{StaticResource WinBtn}"
                            ToolTip="Close"
                            Click="CloseButton_Click"/>
                </StackPanel>
            </Grid>

            <!-- ═══ NAV BAR ════════════════════════════════════════════════ -->
            <Border Grid.Row="1"
                    Background="#1A1A1C"
                    BorderBrush="{StaticResource BorderNormalBrush}"
                    BorderThickness="0,0,0,1">
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="12,0">
                    <RadioButton x:Name="NavControls"
                                 Content="Controls"
                                 GroupName="NavGroup"
                                 IsChecked="True"
                                 Style="{StaticResource NavBtn}"
                                 Checked="NavBtn_Checked"/>
                    <RadioButton x:Name="NavSystemFiles"
                                 Content="System Files"
                                 GroupName="NavGroup"
                                 Style="{StaticResource NavBtn}"
                                 Checked="NavBtn_Checked"/>
                    <RadioButton x:Name="NavCores"
                                 Content="Cores"
                                 GroupName="NavGroup"
                                 Style="{StaticResource NavBtn}"
                                 Checked="NavBtn_Checked"/>
                    <RadioButton x:Name="NavLibrary"
                                 Content="Library"
                                 GroupName="NavGroup"
                                 Style="{StaticResource NavBtn}"
                                 Checked="NavBtn_Checked"/>
                    <RadioButton x:Name="NavTheme"
                                 Content="Theme"
                                 GroupName="NavGroup"
                                 Style="{StaticResource NavBtn}"
                                 Checked="NavBtn_Checked"/>
                    <RadioButton x:Name="NavSnaps"
                                 Content="Snaps"
                                 GroupName="NavGroup"
                                 Style="{StaticResource NavBtn}"
                                 Checked="NavBtn_Checked"/>
                    <RadioButton x:Name="NavCoreOptions"
                                 Content="Core Options"
                                 GroupName="NavGroup"
                                 Style="{StaticResource NavBtn}"
                                 Checked="NavBtn_Checked"/>
                </StackPanel>
            </Border>

            <!-- ═══ CONTENT ════════════════════════════════════════════════ -->
            <Grid Grid.Row="2">

                <!-- ── PANEL: Controls ──────────────────────────────────── -->
                <Grid x:Name="PanelControls">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="310" MinWidth="280"/>
                    </Grid.ColumnDefinitions>

                    <!-- LEFT: Controller image -->
                    <Border Grid.Column="0"
                            Background="#0C0C0E"
                            BorderBrush="{StaticResource BorderNormalBrush}"
                            BorderThickness="0,0,1,0">
                        <Image x:Name="ControllerImage"
                               Stretch="Uniform"
                               Margin="40"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Border>

                    <!-- RIGHT: Controls panel -->
                    <Grid Grid.Column="1" Background="{StaticResource BgSecondaryBrush}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Top: System / Player / section header -->
                        <StackPanel Grid.Row="0" Margin="16,14,16,0">

                            <TextBlock Text="SYSTEM" Style="{StaticResource PrefLabel}" Margin="0,0,0,4"/>
                            <ComboBox x:Name="SystemComboBox"
                                      Style="{StaticResource PrefComboBox}"
                                      DisplayMemberPath="Name"
                                      SelectionChanged="SystemComboBox_SelectionChanged"/>

                            <TextBlock Text="PLAYER" Style="{StaticResource PrefLabel}"/>
                            <ComboBox x:Name="PlayerComboBox"
                                      Style="{StaticResource PrefComboBox}"
                                      SelectionChanged="PlayerComboBox_SelectionChanged">
                                <ComboBoxItem Content="Player 1"/>
                                <ComboBoxItem Content="Player 2"/>
                                <ComboBoxItem Content="Player 3"/>
                                <ComboBoxItem Content="Player 4"/>
                            </ComboBox>

                            <TextBlock Text="GAMEPLAY BUTTONS"
                                       Style="{StaticResource PrefLabel}"
                                       Margin="0,16,0,6"/>
                            <Rectangle Height="1"
                                       Fill="{StaticResource BorderNormalBrush}"
                                       Margin="0,0,0,2"/>
                        </StackPanel>

                        <!-- Middle: Scrollable button list -->
                        <ScrollViewer Grid.Row="1"
                                      Margin="16,4,4,0"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel x:Name="ButtonsPanel" Margin="0,0,12,8"/>
                        </ScrollViewer>

                        <!-- Bottom: Input device + actions -->
                        <Border Grid.Row="2"
                                Background="{StaticResource BgPrimaryBrush}"
                                BorderBrush="{StaticResource BorderNormalBrush}"
                                BorderThickness="0,1,0,0"
                                Padding="16,12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0">
                                    <TextBlock Text="INPUT DEVICE" Style="{StaticResource PrefLabel}" Margin="0,0,0,4"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ComboBox x:Name="InputDeviceComboBox"
                                                  Grid.Column="0"
                                                  Style="{StaticResource PrefComboBox}"
                                                  SelectionChanged="InputDeviceComboBox_SelectionChanged"/>
                                        <Button Grid.Column="1"
                                                Content="&#x21BA;"
                                                Style="{StaticResource SecondaryBtn}"
                                                Padding="10,8"
                                                Margin="6,0,0,0"
                                                FontSize="16"
                                                ToolTip="Refresh devices"
                                                Click="RefreshDevicesButton_Click"/>
                                    </Grid>
                                </StackPanel>

                                <StackPanel Grid.Row="1"
                                            Orientation="Horizontal"
                                            HorizontalAlignment="Right"
                                            Margin="0,10,0,0">
                                    <Button Content="Reset Defaults"
                                            Style="{StaticResource SecondaryBtn}"
                                            Margin="0,0,8,0"
                                            Click="ResetDefaultsButton_Click"/>
                                    <Button Content="Save"
                                            Style="{StaticResource ActionBtn}"
                                            Click="SaveButton_Click"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>

                <!-- ── PANEL: System Files ──────────────────────────────── -->
                <Grid x:Name="PanelSystemFiles" Visibility="Collapsed">
                    <ScrollViewer Margin="24,16,24,16" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="BiosPanel"/>
                    </ScrollViewer>
                </Grid>

                <!-- ── PANEL: Cores ─────────────────────────────────────── -->
                <Grid x:Name="PanelCores" Visibility="Collapsed">
                    <ScrollViewer Margin="24,16,24,16" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="CoresListPanel"/>
                    </ScrollViewer>
                </Grid>

                <!-- ── PANEL: Library ───────────────────────────────────── -->
                <Grid x:Name="PanelLibrary" Visibility="Collapsed">
                    <StackPanel Margin="32,24,32,24" MaxWidth="600" HorizontalAlignment="Left">

                        <!-- Folder picker header -->
                        <TextBlock Text="GAME LIBRARY FOLDER" Style="{StaticResource PrefLabel}"/>
                        <TextBlock TextWrapping="Wrap" FontSize="12" Margin="0,0,0,8"
                                   Foreground="{StaticResource TextSecondaryBrush}">
                            <Run>Set a folder where OpenEmu can copy imported games. </Run>
                            <Run FontStyle="Italic">If no folder is set, or if you choose "Keep in original location" below, your ROMs will never be moved — OpenEmu will simply reference them where they already are.</Run>
                        </TextBlock>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="{StaticResource BgTertiaryBrush}"
                                    BorderBrush="{StaticResource BorderNormalBrush}" BorderThickness="1"
                                    CornerRadius="6" Padding="10,8">
                                <TextBlock x:Name="LibraryPathText" Text="Not set — games will stay in their original location"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="12" VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>
                            </Border>
                            <Button x:Name="BrowseLibraryBtn" Grid.Column="1"
                                    Content="Browse&#x2026;" Style="{StaticResource SecondaryBtn}"
                                    Margin="8,0,0,0" Padding="14,8"
                                    Click="BrowseLibraryBtn_Click"/>
                        </Grid>

                        <Rectangle Height="1" Fill="{StaticResource BorderNormalBrush}" Margin="0,24,0,16"/>

                        <!-- Import behaviour -->
                        <TextBlock Text="IMPORT BEHAVIOUR" Style="{StaticResource PrefLabel}" Margin="0,0,0,4"/>
                        <TextBlock Text="Choose what happens when you add games to your library."
                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"
                                   TextWrapping="Wrap" Margin="0,0,0,12"/>

                        <RadioButton x:Name="LibraryKeepInPlace" GroupName="LibImport"
                                     IsChecked="True"
                                     Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"
                                     Margin="0,0,0,4" Cursor="Hand">
                            <StackPanel>
                                <TextBlock Text="Keep games in their original location" FontSize="13"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="OpenEmu tracks where your files are — nothing is copied or moved."
                                           FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="0,2,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton x:Name="LibraryCopyFiles" GroupName="LibImport"
                                     Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"
                                     Margin="0,10,0,16" Cursor="Hand">
                            <StackPanel>
                                <TextBlock Text="Copy games to the library folder" FontSize="13"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="A copy of each ROM is placed in your library folder. Requires a folder to be set above."
                                           FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="0,2,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </RadioButton>

                        <CheckBox x:Name="LibraryOrganizeByConsole"
                                  Content="Organize copied games into sub-folders by console"
                                  Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"
                                  Margin="22,0,0,0"/>

                        <Button Content="Save" Style="{StaticResource ActionBtn}"
                                HorizontalAlignment="Left" Margin="0,24,0,0"
                                Click="LibrarySaveBtn_Click"/>

                        <Rectangle Height="1" Fill="{StaticResource BorderNormalBrush}" Margin="0,24,0,16"/>

                        <!-- Database Maintenance -->
                        <TextBlock Text="DATABASE MAINTENANCE" Style="{StaticResource PrefLabel}" Margin="0,0,0,4"/>
                        <TextBlock Text="Reclaim disk space by compacting the library database. Safe to run at any time."
                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"
                                   TextWrapping="Wrap" Margin="0,0,0,12"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Button x:Name="VacuumBtn" Content="Optimize Database"
                                    Style="{StaticResource SecondaryBtn}"
                                    Padding="14,8"
                                    Click="VacuumBtn_Click"/>
                            <TextBlock x:Name="VacuumStatusText"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="12" VerticalAlignment="Center"
                                       Margin="12,0,0,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="BackupBtn" Content="Backup Database…"
                                    Style="{StaticResource SecondaryBtn}"
                                    Padding="14,8"
                                    Click="BackupBtn_Click"/>
                            <TextBlock x:Name="BackupStatusText"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="12" VerticalAlignment="Center"
                                       Margin="12,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <!-- ── PANEL: Theme ─────────────────────────────────────────── -->
                <Grid x:Name="PanelTheme" Visibility="Collapsed">
                    <ScrollViewer Margin="32,24,32,24" VerticalScrollBarVisibility="Auto">
                        <StackPanel MaxWidth="560" HorizontalAlignment="Left">

                            <!-- Layout section -->
                            <TextBlock Text="LAYOUT" Style="{StaticResource PrefLabel}"/>
                            <Rectangle Height="1" Fill="{StaticResource BorderNormalBrush}" Margin="0,0,0,16"/>

                            <!-- Grid Padding -->
                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Grid edge padding"
                                               FontSize="13" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Space between the grid and the window edge."
                                               FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                               Margin="0,2,0,8" TextWrapping="Wrap"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="40"/>
                                        </Grid.ColumnDefinitions>
                                        <Slider x:Name="PaddingSlider"
                                                Grid.Column="0"
                                                Minimum="8" Maximum="64" TickFrequency="2"
                                                IsSnapToTickEnabled="True"
                                                VerticalAlignment="Center"
                                                ValueChanged="PaddingSlider_ValueChanged"/>
                                        <TextBlock x:Name="PaddingValueLabel"
                                                   Grid.Column="1"
                                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                </StackPanel>
                            </Grid>

                            <!-- Card Size -->
                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Card size"
                                               FontSize="13" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Width of each game card. Height adjusts automatically to match the console's box art ratio."
                                               FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                               Margin="0,2,0,8" TextWrapping="Wrap"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="40"/>
                                        </Grid.ColumnDefinitions>
                                        <Slider x:Name="CardSizeSlider"
                                                Grid.Column="0"
                                                Minimum="148" Maximum="280" TickFrequency="8"
                                                IsSnapToTickEnabled="True"
                                                VerticalAlignment="Center"
                                                ValueChanged="CardSizeSlider_ValueChanged"/>
                                        <TextBlock x:Name="CardSizeValueLabel"
                                                   Grid.Column="1"
                                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                </StackPanel>
                            </Grid>

                            <!-- Card Spacing -->
                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Card spacing"
                                               FontSize="13" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Gap between individual game cards."
                                               FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                               Margin="0,2,0,8" TextWrapping="Wrap"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="40"/>
                                        </Grid.ColumnDefinitions>
                                        <Slider x:Name="SpacingSlider"
                                                Grid.Column="0"
                                                Minimum="4" Maximum="48" TickFrequency="2"
                                                IsSnapToTickEnabled="True"
                                                VerticalAlignment="Center"
                                                ValueChanged="SpacingSlider_ValueChanged"/>
                                        <TextBlock x:Name="SpacingValueLabel"
                                                   Grid.Column="1"
                                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                </StackPanel>
                            </Grid>

                            <Rectangle Height="1" Fill="{StaticResource BorderNormalBrush}" Margin="0,4,0,20"/>

                            <!-- Window style section -->
                            <TextBlock Text="WINDOW STYLE" Style="{StaticResource PrefLabel}"/>
                            <Rectangle Height="1" Fill="{StaticResource BorderNormalBrush}" Margin="0,0,0,16"/>

                            <!-- Windows Chrome toggle -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                    <TextBlock Text="Use Windows chrome"
                                               FontSize="13" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                               Margin="0,4,0,0" TextWrapping="Wrap">
                                        <Run>Replaces the custom macOS-style title bar and window buttons with the standard Windows chrome — including snap layouts and the native minimize, maximize and close buttons.</Run>
                                    </TextBlock>
                                    <TextBlock x:Name="ChromeRestartNote"
                                               Text="&#x26A0;&#xFE0F;  Takes effect after restarting Emutastic."
                                               FontSize="11" Foreground="#FFB347"
                                               Margin="0,6,0,0"
                                               Visibility="Collapsed"/>
                                </StackPanel>
                                <ToggleButton x:Name="WindowsChromeToggle"
                                              Grid.Column="1"
                                              Style="{StaticResource ToggleSwitch}"
                                              VerticalAlignment="Top"
                                              Margin="0,2,0,0"
                                              Checked="WindowsChromeToggle_Changed"
                                              Unchecked="WindowsChromeToggle_Changed"/>
                            </Grid>

                            <Rectangle Height="1" Fill="{StaticResource BorderNormalBrush}" Margin="0,20,0,20"/>

                            <Button x:Name="ThemeSaveBtn"
                                    Content="Save"
                                    Style="{StaticResource ActionBtn}"
                                    HorizontalAlignment="Left"
                                    Click="ThemeSaveBtn_Click"/>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <!-- ── PANEL: Snaps ─────────────────────────────────────────── -->
                <Grid x:Name="PanelSnaps" Visibility="Collapsed">
                    <ScrollViewer Margin="32,24,32,24" VerticalScrollBarVisibility="Auto">
                        <StackPanel MaxWidth="560" HorizontalAlignment="Left">

                            <TextBlock Text="VIDEO SNAPS" Style="{StaticResource PrefLabel}"/>
                            <Rectangle Height="1" Fill="{StaticResource BorderNormalBrush}" Margin="0,0,0,16"/>

                            <TextBlock Text="When a game card is opened, Emutastic can play a video preview instead of showing a static screenshot. Choose a provider below."
                                       FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap" Margin="0,0,0,24"/>

                            <!-- Provider pill selector -->
                            <Border Background="{StaticResource BgTertiaryBrush}"
                                    CornerRadius="8" Padding="4" Margin="0,0,0,28"
                                    HorizontalAlignment="Left">
                                <StackPanel Orientation="Horizontal">
                                    <RadioButton x:Name="SnapProviderSS"
                                                 Content="ScreenScraper"
                                                 GroupName="SnapProvider"
                                                 IsChecked="True"
                                                 Checked="SnapProvider_Checked"
                                                 Style="{StaticResource ProviderPill}"/>
                                    <RadioButton x:Name="SnapProviderEM"
                                                 Content="EmuMovies"
                                                 GroupName="SnapProvider"
                                                 Checked="SnapProvider_Checked"
                                                 Style="{StaticResource ProviderPill}"/>
                                </StackPanel>
                            </Border>

                            <!-- ScreenScraper panel -->
                            <StackPanel x:Name="PanelSS">
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="ScreenScraper"
                                                   FontSize="15" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="Free accounts available at screenscraper.fr — no developer registration required."
                                                   FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <ToggleButton x:Name="SSEnabledToggle"
                                                 Grid.Column="1"
                                                 Style="{StaticResource ToggleSwitch}"
                                                 VerticalAlignment="Center"
                                                 Checked="SSEnabled_Changed"
                                                 Unchecked="SSEnabled_Changed"/>
                                </Grid>

                                <TextBlock Text="Username" FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                <TextBox x:Name="SSUsernameBox"
                                         Style="{StaticResource DarkTextBox}"
                                         Margin="0,0,0,14"/>

                                <TextBlock Text="Password" FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                <PasswordBox x:Name="SSPasswordBox"
                                             Style="{StaticResource DarkPasswordBox}"
                                             Margin="0,0,0,20"/>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Button x:Name="SSTestBtn"
                                            Content="Test Connection"
                                            Style="{StaticResource ActionBtn}"
                                            Click="SSTestBtn_Click"
                                            Margin="0,0,12,0"/>
                                    <TextBlock x:Name="SSStatusLabel"
                                               FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- EmuMovies panel (scaffolded, not yet active) -->
                            <StackPanel x:Name="PanelEM" Visibility="Collapsed">
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="EmuMovies"
                                                   FontSize="15" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="EmuMovies developer API access is required. Support is coming once their v3 API ships."
                                                   FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <Border Grid.Column="1"
                                            Background="{StaticResource BgTertiaryBrush}"
                                            BorderBrush="{StaticResource BorderNormalBrush}"
                                            BorderThickness="1"
                                            CornerRadius="6" Padding="10,4"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="Coming Soon"
                                                   FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextMutedBrush}"/>
                                    </Border>
                                </Grid>

                                <TextBlock Text="Username" FontSize="12"
                                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6"/>
                                <TextBox Style="{StaticResource DarkTextBox}" IsEnabled="False"
                                         Margin="0,0,0,14"/>

                                <TextBlock Text="Password" FontSize="12"
                                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6"/>
                                <PasswordBox Style="{StaticResource DarkPasswordBox}" IsEnabled="False"
                                             Margin="0,0,0,20"/>

                                <Button Content="Request Developer Access"
                                        Style="{StaticResource ActionBtn}"
                                        IsEnabled="False"/>
                            </StackPanel>

                            <Rectangle Height="1" Fill="{StaticResource BorderNormalBrush}" Margin="0,20,0,20"/>
                            <Button x:Name="SnapsSaveBtn"
                                    Content="Save"
                                    Style="{StaticResource ActionBtn}"
                                    HorizontalAlignment="Left"
                                    Click="SnapsSaveBtn_Click"/>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <!-- ── PANEL: Core Options ──────────────────────────────── -->
                <Grid x:Name="PanelCoreOptions" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200" MinWidth="160"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: core list -->
                    <Border Grid.Column="0"
                            Background="{StaticResource BgSecondaryBrush}"
                            BorderBrush="{StaticResource BorderNormalBrush}"
                            BorderThickness="0,0,1,0">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top"
                                       Text="CORES"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       Margin="14,14,14,8"/>
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="CoreOptionsCoreList" Margin="6,0,6,8"/>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>

                    <!-- Right: options for selected core -->
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <ScrollViewer Grid.Row="0"
                                      Margin="24,16,24,8"
                                      VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="CoreOptionsOptionList"/>
                        </ScrollViewer>

                        <Border Grid.Row="1"
                                Background="{StaticResource BgSecondaryBrush}"
                                BorderBrush="{StaticResource BorderNormalBrush}"
                                BorderThickness="0,1,0,0"
                                Padding="24,10">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button x:Name="CoreOptionsResetBtn"
                                        Content="Reset to Defaults"
                                        Style="{StaticResource SecondaryBtn}"
                                        Margin="0,0,8,0"
                                        IsEnabled="False"
                                        Click="CoreOptionsReset_Click"/>
                                <Button x:Name="CoreOptionsSaveBtn"
                                        Content="Save"
                                        Style="{StaticResource ActionBtn}"
                                        IsEnabled="False"
                                        Click="CoreOptionsSave_Click"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>

            </Grid>
        </Grid>
    </Border>
</Window>
