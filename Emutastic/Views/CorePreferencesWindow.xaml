<Window x:Class="Emutastic.Views.CorePreferencesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Emutastic.Views"
        Title="Core Preferences" 
        Height="600" Width="700"
        MinHeight="400" MinWidth="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Themes/DarkTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            
        <Style x:Key="HeaderTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        </Style>

        <Style x:Key="SubHeaderTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="ConsoleNameStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="CoreComboStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource BgQuaternaryBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderNormalBrush}"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="InstalledCoreStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource GreenBrush}"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <Style x:Key="MissingCoreStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource WarningBrush}"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <Style x:Key="CoreComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Background" Value="{StaticResource BgSecondaryBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Padding" Value="8,5"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <local:InstalledStatusConverter x:Key="InstalledStatusConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Background="{StaticResource PillGroupBgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{StaticResource PillBgBrush}"
                Padding="20,15"
                BorderBrush="{StaticResource BorderNormalBrush}"
                BorderThickness="0,0,0,1">
            <StackPanel>
                <TextBlock Text="Core Preferences" 
                          Style="{StaticResource HeaderTextStyle}"/>
                <TextBlock Text="Select your preferred core for each console. The selected core will be used when launching games. If your preferred core is not available, the default will be used." 
                          Style="{StaticResource SubHeaderTextStyle}"
                          Margin="0,8,0,0"/>
            </StackPanel>
        </Border>

        <!-- Console List -->
        <ScrollViewer Grid.Row="1" 
                      VerticalScrollBarVisibility="Auto"
                      Background="{StaticResource PillGroupBgBrush}"
                      Padding="15">
            <ItemsControl x:Name="ConsoleList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource PillBgBrush}"
                                CornerRadius="6"
                                Margin="0,4"
                                Padding="15,12">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Console Name -->
                                    <TextBlock Grid.Column="0"
                                              Text="{Binding ConsoleName}"
                                              Style="{StaticResource ConsoleNameStyle}"/>

                                    <!-- Core Selection -->
                                    <ComboBox Grid.Column="1"
                                             ItemsSource="{Binding AvailableCores}"
                                             SelectedItem="{Binding SelectedCore, Mode=TwoWay}"
                                             DisplayMemberPath="DisplayName"
                                             Style="{StaticResource CoreComboStyle}"
                                             ItemContainerStyle="{StaticResource CoreComboBoxItemStyle}"
                                             Margin="10,0">
                                    </ComboBox>

                                    <!-- Installation Status -->
                                    <TextBlock Grid.Column="2"
                                              Text="{Binding SelectedCore, Converter={StaticResource InstalledStatusConverter}}"
                                              Style="{StaticResource InstalledCoreStyle}"
                                              VerticalAlignment="Center"
                                              Margin="5,0,0,0"/>
                                </Grid>

                                <!-- Per-core options (visible when CoreOptions is non-empty) -->
                                <ItemsControl ItemsSource="{Binding CoreOptions}"
                                              Visibility="{Binding HasCoreOptions, Converter={StaticResource BoolToVisConverter}}"
                                              Margin="140,8,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="10,4,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="120"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                          Text="{Binding DisplayName}"
                                                          Foreground="{StaticResource TextSecondaryBrush}"
                                                          FontSize="12"
                                                          VerticalAlignment="Center"/>
                                                <ComboBox Grid.Column="1"
                                                         ItemsSource="{Binding ValidValues}"
                                                         SelectedItem="{Binding SelectedValue, Mode=TwoWay}"
                                                         Style="{StaticResource CoreComboStyle}"
                                                         ItemContainerStyle="{StaticResource CoreComboBoxItemStyle}"
                                                         Margin="0,0,10,0"/>
                                                <TextBlock Grid.Column="2"
                                                          Text="{Binding Description}"
                                                          Foreground="{StaticResource TextMutedBrush}"
                                                          FontSize="11"
                                                          VerticalAlignment="Center"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2"
                Background="{StaticResource PillBgBrush}"
                Padding="20,15"
                BorderBrush="{StaticResource BorderNormalBrush}"
                BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Reset to Defaults"
                        x:Name="ResetButton"
                        Click="ResetButton_Click"
                        Background="{StaticResource SurfaceBrush}"
                        Foreground="{StaticResource TextPrimaryBrush}"
                        BorderBrush="{StaticResource BorderNormalBrush}"
                        Padding="15,8"
                        Margin="0,0,10,0"/>
                <Button Content="Close"
                        IsDefault="True"
                        IsCancel="True"
                        Click="CloseButton_Click"
                        Background="{StaticResource AccentBrush}"
                        Foreground="White"
                        BorderBrush="{StaticResource AccentPressedBrush}"
                        Padding="20,8"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
