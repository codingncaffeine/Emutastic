<Window x:Class="Emutastic.Views.BiosRequiredWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Width="440" SizeToContent="Height"
        WindowStartupLocation="CenterOwner">

    <Border Background="{StaticResource BgSecondaryBrush}"
            BorderBrush="{StaticResource BorderNormalBrush}"
            BorderThickness="1"
            CornerRadius="10">
        <StackPanel Margin="24">

            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="⚠"
                           FontSize="16"
                           Foreground="#E8A020"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                <TextBlock Text="BIOS Required"
                           FontFamily="{StaticResource PrimaryFont}"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <TextBlock x:Name="MessageText"
                       FontFamily="{StaticResource PrimaryFont}"
                       FontSize="12"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,10"/>

            <Border Background="{StaticResource BgTertiaryBrush}"
                    BorderBrush="{StaticResource BorderSubtleBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="10,8"
                    Margin="0,0,0,16">
                <TextBlock x:Name="BiosFilesText"
                           FontFamily="Consolas, Courier New"
                           FontSize="12"
                           Foreground="{StaticResource AccentBrush}"
                           TextWrapping="Wrap"/>
            </Border>

            <TextBlock x:Name="SystemDirText"
                       FontFamily="{StaticResource PrimaryFont}"
                       FontSize="11"
                       Foreground="{StaticResource TextMutedBrush}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,16"/>

            <Button Content="OK"
                    Style="{StaticResource PlayButtonStyle}"
                    Padding="24,8"
                    HorizontalAlignment="Right"
                    Click="OK_Click"/>

        </StackPanel>
    </Border>
</Window>
