<Window x:Class="Emutastic.Views.NewCollectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Width="400" Height="180"
        WindowStartupLocation="CenterOwner">

    <Border Background="{StaticResource BgSecondaryBrush}"
            BorderBrush="{StaticResource BorderNormalBrush}"
            BorderThickness="1"
            CornerRadius="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="0" Opacity="0.65" Color="#000000"/>
        </Border.Effect>
        <StackPanel Margin="24">
            <TextBlock Text="New Collection"
                       FontFamily="{StaticResource PrimaryFont}"
                       FontSize="15"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       Margin="0,0,0,14"/>
            <Border Background="{StaticResource BgTertiaryBrush}"
                    BorderBrush="{StaticResource BorderSubtleBrush}"
                    BorderThickness="1"
                    CornerRadius="6">
                <TextBox x:Name="NameBox"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         CaretBrush="{StaticResource AccentBrush}"
                         FontFamily="{StaticResource PrimaryFont}"
                         FontSize="13"
                         Padding="10,8"
                         KeyDown="NameBox_KeyDown"/>
            </Border>
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,14,0,0">
                <Button Content="Cancel"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Padding="16,8"
                        Margin="0,0,8,0"
                        Click="Cancel_Click"/>
                <Button Content="Create"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Padding="16,8"
                        Click="Create_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
