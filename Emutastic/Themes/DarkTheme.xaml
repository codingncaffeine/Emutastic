<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── COLORS ── -->
    <Color x:Key="BgPrimaryColor">#0F0F10</Color>
    <Color x:Key="BgSecondaryColor">#181819</Color>
    <Color x:Key="BgTertiaryColor">#1F1F21</Color>
    <Color x:Key="BgQuaternaryColor">#272729</Color>
    <Color x:Key="BorderSubtleColor">#1A1A1C</Color>
    <Color x:Key="BorderNormalColor">#2A2A2D</Color>
    <Color x:Key="TextPrimaryColor">#F0F0F0</Color>
    <Color x:Key="TextSecondaryColor">#8A8A90</Color>
    <Color x:Key="TextMutedColor">#555558</Color>
    <Color x:Key="AccentColor">#E03535</Color>
    <Color x:Key="AccentHoverColor">#EB5555</Color>
    <Color x:Key="GreenColor">#28C840</Color>

    <!-- Scrollbar -->
    <Color x:Key="ScrollThumbColor">#484849</Color>
    <Color x:Key="ScrollThumbHoverColor">#666668</Color>
    <Color x:Key="ScrollThumbDragColor">#888889</Color>
    <Color x:Key="ScrollTrackColor">#222224</Color>

    <!-- Play Button -->
    <Color x:Key="PlayBtnBgColor">#2C2C2E</Color>
    <Color x:Key="PlayBtnBorderColor">#3A3A3C</Color>
    <Color x:Key="PlayBtnHoverBgColor">#3A3A3C</Color>
    <Color x:Key="PlayBtnHoverBorderColor">#48484A</Color>
    <Color x:Key="PlayBtnPressedBgColor">#1C1C1E</Color>

    <!-- Accent State Variants -->
    <Color x:Key="AccentPressedColor">#C02020</Color>
    <Color x:Key="AccentDisabledColor">#6B2020</Color>

    <!-- Traffic Light Window Buttons -->
    <Color x:Key="TrafficYellowColor">#FEBC2E</Color>
    <Color x:Key="TrafficYellowHoverColor">#E5A800</Color>
    <Color x:Key="TrafficGreenHoverColor">#1FA832</Color>
    <Color x:Key="TrafficRedColor">#FF5F57</Color>
    <Color x:Key="TrafficRedHoverColor">#E5453D</Color>

    <!-- Overlay (Emulator) -->
    <Color x:Key="OverlayBgColor">#121214</Color>

    <!-- Shadow -->
    <Color x:Key="ShadowColor">#000000</Color>

    <!-- Pill Controls (toolbar view-mode buttons, etc.) -->
    <Color x:Key="PillBgColor">#2D2D2D</Color>
    <Color x:Key="PillBorderColor">#1A1A1A</Color>
    <Color x:Key="PillHoverBgColor">#555555</Color>
    <Color x:Key="PillPressedBgColor">#3D3D3D</Color>
    <Color x:Key="PillFgColor">#E0E0E0</Color>
    <Color x:Key="PillMutedFgColor">#A0A0A0</Color>

    <!-- Interactive Surfaces (toggle tracks, nav pills, controls) -->
    <Color x:Key="SurfaceColor">#3A3A3E</Color>
    <Color x:Key="SurfaceHoverColor">#2E2E32</Color>
    <Color x:Key="SurfaceActiveColor">#4A4A4F</Color>
    <Color x:Key="ContentBgColor">#0C0C0E</Color>
    <Color x:Key="WarningColor">#FFB347</Color>

    <!-- Pill Group Container -->
    <Color x:Key="PillGroupBgColor">#1E1E1E</Color>

    <!-- Achievement Toast -->
    <Color x:Key="AchievementGoldColor">#FFD700</Color>

    <!-- Favorites Heart -->
    <Color x:Key="FavoriteHeartColor">#FFFF6B6B</Color>

    <!-- ── BRUSHES ── -->
    <SolidColorBrush x:Key="BgPrimaryBrush"     Color="{StaticResource BgPrimaryColor}"/>
    <SolidColorBrush x:Key="BgSecondaryBrush"   Color="{StaticResource BgSecondaryColor}"/>
    <SolidColorBrush x:Key="BgTertiaryBrush"    Color="{StaticResource BgTertiaryColor}"/>
    <SolidColorBrush x:Key="BgQuaternaryBrush"  Color="{StaticResource BgQuaternaryColor}"/>
    <SolidColorBrush x:Key="BorderSubtleBrush"  Color="{StaticResource BorderSubtleColor}"/>
    <SolidColorBrush x:Key="BorderNormalBrush"   Color="{StaticResource BorderNormalColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush"   Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextMutedBrush"     Color="{StaticResource TextMutedColor}"/>
    <SolidColorBrush x:Key="AccentBrush"        Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentHoverBrush"   Color="{StaticResource AccentHoverColor}"/>
    <SolidColorBrush x:Key="GreenBrush"         Color="{StaticResource GreenColor}"/>

    <SolidColorBrush x:Key="ShadowBrush"           Color="{StaticResource ShadowColor}"/>
    <SolidColorBrush x:Key="OverlayBgBrush"       Color="{StaticResource OverlayBgColor}"/>
    <SolidColorBrush x:Key="AccentPressedBrush"   Color="{StaticResource AccentPressedColor}"/>
    <SolidColorBrush x:Key="AccentDisabledBrush"   Color="{StaticResource AccentDisabledColor}"/>

    <SolidColorBrush x:Key="ScrollThumbBrush"      Color="{StaticResource ScrollThumbColor}"/>
    <SolidColorBrush x:Key="ScrollThumbHoverBrush"  Color="{StaticResource ScrollThumbHoverColor}"/>
    <SolidColorBrush x:Key="ScrollThumbDragBrush"   Color="{StaticResource ScrollThumbDragColor}"/>
    <SolidColorBrush x:Key="ScrollTrackBrush"       Color="{StaticResource ScrollTrackColor}"/>

    <SolidColorBrush x:Key="PlayBtnBgBrush"           Color="{StaticResource PlayBtnBgColor}"/>
    <SolidColorBrush x:Key="PlayBtnBorderBrush"       Color="{StaticResource PlayBtnBorderColor}"/>
    <SolidColorBrush x:Key="PlayBtnHoverBgBrush"      Color="{StaticResource PlayBtnHoverBgColor}"/>
    <SolidColorBrush x:Key="PlayBtnHoverBorderBrush"  Color="{StaticResource PlayBtnHoverBorderColor}"/>
    <SolidColorBrush x:Key="PlayBtnPressedBgBrush"    Color="{StaticResource PlayBtnPressedBgColor}"/>

    <SolidColorBrush x:Key="TrafficYellowBrush"       Color="{StaticResource TrafficYellowColor}"/>
    <SolidColorBrush x:Key="TrafficYellowHoverBrush"   Color="{StaticResource TrafficYellowHoverColor}"/>
    <SolidColorBrush x:Key="TrafficGreenHoverBrush"    Color="{StaticResource TrafficGreenHoverColor}"/>
    <SolidColorBrush x:Key="TrafficRedBrush"           Color="{StaticResource TrafficRedColor}"/>
    <SolidColorBrush x:Key="TrafficRedHoverBrush"      Color="{StaticResource TrafficRedHoverColor}"/>

    <SolidColorBrush x:Key="PillBgBrush"         Color="{StaticResource PillBgColor}"/>
    <SolidColorBrush x:Key="PillBorderBrush"     Color="{StaticResource PillBorderColor}"/>
    <SolidColorBrush x:Key="PillHoverBgBrush"    Color="{StaticResource PillHoverBgColor}"/>
    <SolidColorBrush x:Key="PillPressedBgBrush"  Color="{StaticResource PillPressedBgColor}"/>
    <SolidColorBrush x:Key="PillFgBrush"         Color="{StaticResource PillFgColor}"/>
    <SolidColorBrush x:Key="PillMutedFgBrush"    Color="{StaticResource PillMutedFgColor}"/>

    <SolidColorBrush x:Key="SurfaceBrush"        Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="SurfaceHoverBrush"   Color="{StaticResource SurfaceHoverColor}"/>
    <SolidColorBrush x:Key="SurfaceActiveBrush"  Color="{StaticResource SurfaceActiveColor}"/>
    <SolidColorBrush x:Key="ContentBgBrush"      Color="{StaticResource ContentBgColor}"/>
    <SolidColorBrush x:Key="WarningBrush"        Color="{StaticResource WarningColor}"/>

    <SolidColorBrush x:Key="AchievementGoldBrush" Color="{StaticResource AchievementGoldColor}"/>

    <SolidColorBrush x:Key="PillGroupBgBrush"    Color="{StaticResource PillGroupBgColor}"/>
    <SolidColorBrush x:Key="FavoriteHeartBrush"  Color="{StaticResource FavoriteHeartColor}"/>

    <!-- ── TYPOGRAPHY ── -->
    <FontFamily x:Key="PrimaryFont">Segoe UI Variable, Segoe UI, sans-serif</FontFamily>

    <!-- ── SCROLLBAR (global implicit styles — apply to every window) ── -->

    <!-- Thumb: rounded pill, visible but not intrusive -->
    <Style x:Key="ScrollBarThumb" TargetType="{x:Type Thumb}">
        <Setter Property="Background" Value="{DynamicResource ScrollThumbBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Thumb}">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="4"
                            Margin="3,2,3,2"
                            Cursor="Hand"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource ScrollThumbHoverBrush}"/>
            </Trigger>
            <Trigger Property="IsDragging" Value="True">
                <Setter Property="Background" Value="{DynamicResource ScrollThumbDragBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Implicit ScrollBar: 10px wide, no arrow buttons, transparent track -->
    <Style TargetType="{x:Type ScrollBar}">
        <Setter Property="Background"    Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Width"         Value="10"/>
        <Setter Property="MinWidth"      Value="10"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ScrollBar}">
                    <Grid Background="Transparent">
                        <!-- Subtle track rail so the scrollbar is always visible -->
                        <Border Background="{DynamicResource ScrollTrackBrush}" CornerRadius="4" Margin="3,2,3,2"/>
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageUpCommand"
                                              Background="Transparent" BorderThickness="0"
                                              Focusable="False" IsTabStop="False"
                                              Height="0"/>
                            </Track.DecreaseRepeatButton>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageDownCommand"
                                              Background="Transparent" BorderThickness="0"
                                              Focusable="False" IsTabStop="False"
                                              Height="0"/>
                            </Track.IncreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Style="{StaticResource ScrollBarThumb}" MinHeight="32"/>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <!-- Horizontal variant -->
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Height"    Value="10"/>
                <Setter Property="MinHeight" Value="10"/>
                <Setter Property="Width"     Value="Auto"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type ScrollBar}">
                            <Grid Background="Transparent">
                                <Track x:Name="PART_Track" IsDirectionReversed="False">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Command="ScrollBar.PageLeftCommand"
                                                      Background="Transparent" BorderThickness="0"
                                                      Focusable="False" IsTabStop="False"
                                                      Width="0"/>
                                    </Track.DecreaseRepeatButton>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Command="ScrollBar.PageRightCommand"
                                                      Background="Transparent" BorderThickness="0"
                                                      Focusable="False" IsTabStop="False"
                                                      Width="0"/>
                                    </Track.IncreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb Style="{StaticResource ScrollBarThumb}" MinWidth="24"/>
                                    </Track.Thumb>
                                </Track>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Implicit ScrollViewer: no horizontal bar, vertical bar flush to right edge -->
    <Style TargetType="{x:Type ScrollViewer}">
        <Setter Property="Background"                   Value="Transparent"/>
        <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="VerticalScrollBarVisibility"   Value="Auto"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ScrollViewer}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ScrollContentPresenter x:Name="PART_ScrollContentPresenter"
                                                Grid.Column="0"
                                                CanContentScroll="{TemplateBinding CanContentScroll}"
                                                ContentTemplate="{TemplateBinding ContentTemplate}"
                                                Margin="{TemplateBinding Padding}"/>
                        <ScrollBar x:Name="PART_VerticalScrollBar"
                                   Grid.Column="1"
                                   Orientation="Vertical"
                                   Value="{TemplateBinding VerticalOffset}"
                                   Maximum="{TemplateBinding ScrollableHeight}"
                                   ViewportSize="{TemplateBinding ViewportHeight}"
                                   Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Keep named variants for any explicit references -->
    <Style x:Key="MinimalScrollBar"    BasedOn="{StaticResource {x:Type ScrollBar}}"    TargetType="{x:Type ScrollBar}"/>
    <Style x:Key="MinimalScrollViewer" BasedOn="{StaticResource {x:Type ScrollViewer}}" TargetType="{x:Type ScrollViewer}"/>

    <!-- ── SIDEBAR ITEM BUTTON ── -->
    <Style x:Key="SidebarItemStyle" TargetType="{x:Type Button}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="10,7"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}"
                            Margin="6,1">
                        <ContentPresenter HorizontalAlignment="Left"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background"
                                    Value="{DynamicResource BgTertiaryBrush}"/>
                            <Setter Property="Foreground"
                                    Value="{DynamicResource TextPrimaryBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background"
                                    Value="{DynamicResource BgQuaternaryBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── PRIMARY BUTTON ── -->
    <Style x:Key="PrimaryButtonStyle" TargetType="{x:Type Button}">
        <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="20,10"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="7"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background"
                                    Value="{DynamicResource AccentHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background"
                                    Value="{DynamicResource AccentBrush}"/>
                            <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── PLAY BUTTON ── -->
    <Style x:Key="PlayButtonStyle" TargetType="{x:Type Button}">
        <Setter Property="Background" Value="{DynamicResource PlayBtnBgBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{DynamicResource PlayBtnBorderBrush}"/>
        <Setter Property="Padding" Value="20,10"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="border"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="7"
                        Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{DynamicResource PlayBtnHoverBgBrush}"/>
                            <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource PlayBtnHoverBorderBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{DynamicResource PlayBtnPressedBgBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── SECONDARY BUTTON ── -->
    <Style x:Key="SecondaryButtonStyle" TargetType="{x:Type Button}">
        <Setter Property="Background" Value="{DynamicResource BgTertiaryBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}"/>
        <Setter Property="Padding" Value="16,10"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="7"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background"
                                    Value="{DynamicResource BgQuaternaryBrush}"/>
                            <Setter Property="Foreground"
                                    Value="{DynamicResource TextPrimaryBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── CONTEXT MENU ── -->
    <Style TargetType="ContextMenu">
        <Setter Property="Background"       Value="{DynamicResource BgTertiaryBrush}"/>
        <Setter Property="BorderBrush"      Value="{DynamicResource BorderNormalBrush}"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="Padding"          Value="4,6"/>
        <Setter Property="FontFamily"       Value="{StaticResource PrimaryFont}"/>
        <Setter Property="HasDropShadow"    Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContextMenu">
                    <!-- Transparent outer margin gives the shadow room to render -->
                    <Border Padding="12">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="28" ShadowDepth="4" Direction="270"
                                                  Opacity="0.55" Color="{StaticResource ShadowColor}"/>
                            </Border.Effect>
                            <StackPanel IsItemsHost="True"
                                        KeyboardNavigation.DirectionalNavigation="Cycle"/>
                        </Border>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── MENU ITEM ── -->
    <Style TargetType="MenuItem">
        <Setter Property="Foreground"  Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="Background"  Value="Transparent"/>
        <Setter Property="FontFamily"  Value="{StaticResource PrimaryFont}"/>
        <Setter Property="FontSize"    Value="13"/>
        <Setter Property="Padding"     Value="10,7"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="MenuItem">
                    <Grid>
                        <!-- Hover / highlight background pill -->
                        <Border x:Name="bg" Background="{TemplateBinding Background}"
                                CornerRadius="6" Margin="4,1"/>

                        <Grid Margin="4,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition x:Name="CheckCol" Width="0"/> <!-- ✓ indicator, hidden by default -->
                                <ColumnDefinition Width="*"/>    <!-- header text -->
                                <ColumnDefinition Width="Auto"/> <!-- submenu arrow -->
                            </Grid.ColumnDefinitions>

                            <!-- Check indicator (only visible when IsChecked) -->
                            <TextBlock x:Name="CheckMark" Grid.Column="0"
                                       Text="✓" FontSize="12"
                                       Foreground="{DynamicResource AccentBrush}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       Visibility="Collapsed"/>

                            <!-- Item text -->
                            <ContentPresenter Grid.Column="1"
                                              ContentSource="Header"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>

                            <!-- Submenu arrow (only for SubmenuHeader role) -->
                            <Path x:Name="Arrow" Grid.Column="2"
                                  Data="M0,0 L4,4 L0,8"
                                  Stroke="{DynamicResource TextSecondaryBrush}"
                                  StrokeThickness="1.5"
                                  VerticalAlignment="Center"
                                  Margin="0,0,10,0"
                                  Visibility="Collapsed"/>
                        </Grid>

                        <!-- Submenu popup -->
                        <Popup x:Name="PART_Popup"
                               Placement="Right"
                               IsOpen="{TemplateBinding IsSubmenuOpen}"
                               AllowsTransparency="True"
                               Focusable="False"
                               PopupAnimation="Fade">
                            <Border Background="{DynamicResource BgTertiaryBrush}"
                                    BorderBrush="{DynamicResource BorderNormalBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="4,6">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="24" ShadowDepth="0" Opacity="0.65" Color="{StaticResource ShadowColor}"/>
                                </Border.Effect>
                                <StackPanel IsItemsHost="True"
                                            KeyboardNavigation.DirectionalNavigation="Cycle"/>
                            </Border>
                        </Popup>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="bg" Property="Background"
                                    Value="{DynamicResource BgQuaternaryBrush}"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                            <Setter TargetName="CheckCol" Property="Width" Value="22"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
                        </Trigger>
                        <Trigger Property="Role" Value="SubmenuHeader">
                            <Setter TargetName="Arrow" Property="Visibility" Value="Visible"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── SEPARATOR ── -->
    <Style TargetType="Separator">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Separator">
                    <Rectangle Height="1"
                               Fill="{DynamicResource BorderNormalBrush}"
                               Margin="10,4"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── TEXT STYLES ── -->
    <Style x:Key="LabelMuted" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
    </Style>

    <Style x:Key="TextPrimary" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="FontSize" Value="13"/>
    </Style>

    <Style x:Key="TextSecondary" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>

</ResourceDictionary>