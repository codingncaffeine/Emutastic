<Window x:Class="Emutastic.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Emutastic"
        mc:Ignorable="d"
        Title="Emutastic"
        Icon="Assets/banners and icons/emutastic-logo.png"
        Height="720" Width="1100"
        MinHeight="500" MinWidth="800"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <DropShadowEffect x:Key="WindowShadow"
                          BlurRadius="30"
                          ShadowDepth="0"
                          Opacity="0.6"
                          Color="#000000"/>

        <!-- Shared trigger logic extracted via a base style is not possible with ControlTemplate,
             so Left and Right caps are defined as two complete styles. -->

        <Style x:Key="TabToggleLeftStyle" TargetType="ToggleButton">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Padding"    Value="12,6"/>
            <Setter Property="Cursor"     Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="pill"
                                Background="#2D2D2D"
                                BorderBrush="#1A1A1A"
                                BorderThickness="1,1,1,1"
                                CornerRadius="10,0,0,10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="#E0E0E0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="pill" Property="Background" Value="#555555"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked"   Value="False"/>
                                </MultiTrigger.Conditions>
                                <MultiTrigger.Setters>
                                    <Setter TargetName="pill" Property="Background" Value="#3D3D3D"/>
                                </MultiTrigger.Setters>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TabToggleRightStyle" TargetType="ToggleButton">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Padding"    Value="12,6"/>
            <Setter Property="Cursor"     Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="pill"
                                Background="#2D2D2D"
                                BorderBrush="#1A1A1A"
                                BorderThickness="0,1,1,1"
                                CornerRadius="0,10,10,0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="#E0E0E0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="pill" Property="Background" Value="#555555"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked"   Value="False"/>
                                </MultiTrigger.Conditions>
                                <MultiTrigger.Setters>
                                    <Setter TargetName="pill" Property="Background" Value="#3D3D3D"/>
                                </MultiTrigger.Setters>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ViewGridStyle" TargetType="ToggleButton">
            <Setter Property="Width"  Value="32"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment"   Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="pill"
                                Background="#2D2D2D"
                                BorderBrush="#1A1A1A"
                                BorderThickness="1,1,1,1"
                                CornerRadius="10,0,0,10">
                            <Viewbox Width="14" Height="14" Stretch="Uniform"
                                     HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Canvas Width="14" Height="14">
                                    <Rectangle x:Name="G1" Canvas.Left="0" Canvas.Top="0" Width="6" Height="6" Fill="#E0E0E0"/>
                                    <Rectangle x:Name="G2" Canvas.Left="8" Canvas.Top="0" Width="6" Height="6" Fill="#E0E0E0"/>
                                    <Rectangle x:Name="G3" Canvas.Left="0" Canvas.Top="8" Width="6" Height="6" Fill="#E0E0E0"/>
                                    <Rectangle x:Name="G4" Canvas.Left="8" Canvas.Top="8" Width="6" Height="6" Fill="#E0E0E0"/>
                                </Canvas>
                            </Viewbox>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="pill" Property="Background" Value="#555555"/>
                                <Setter TargetName="G1"   Property="Fill"       Value="#E0E0E0"/>
                                <Setter TargetName="G2"   Property="Fill"       Value="#E0E0E0"/>
                                <Setter TargetName="G3"   Property="Fill"       Value="#E0E0E0"/>
                                <Setter TargetName="G4"   Property="Fill"       Value="#E0E0E0"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked"   Value="False"/>
                                </MultiTrigger.Conditions>
                                <MultiTrigger.Setters>
                                    <Setter TargetName="pill" Property="Background" Value="#3D3D3D"/>
                                </MultiTrigger.Setters>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ViewListStyle" TargetType="ToggleButton">
            <Setter Property="Width"  Value="32"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment"   Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="pill"
                                Background="#2D2D2D"
                                BorderBrush="#1A1A1A"
                                BorderThickness="0,1,1,1"
                                CornerRadius="0,10,10,0">
                            <Viewbox Width="14" Height="14" Stretch="Uniform"
                                     HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Canvas Width="14" Height="14">
                                    <Rectangle x:Name="L1" Canvas.Left="0" Canvas.Top="0"   Width="14" Height="3" Fill="#E0E0E0"/>
                                    <Rectangle x:Name="L2" Canvas.Left="0" Canvas.Top="5.5" Width="14" Height="3" Fill="#E0E0E0"/>
                                    <Rectangle x:Name="L3" Canvas.Left="0" Canvas.Top="11"  Width="14" Height="3" Fill="#E0E0E0"/>
                                </Canvas>
                            </Viewbox>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="pill" Property="Background" Value="#555555"/>
                                <Setter TargetName="L1"   Property="Fill"       Value="#E0E0E0"/>
                                <Setter TargetName="L2"   Property="Fill"       Value="#E0E0E0"/>
                                <Setter TargetName="L3"   Property="Fill"       Value="#E0E0E0"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked"   Value="False"/>
                                </MultiTrigger.Conditions>
                                <MultiTrigger.Setters>
                                    <Setter TargetName="pill" Property="Background" Value="#3D3D3D"/>
                                </MultiTrigger.Setters>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Border Background="{StaticResource BgPrimaryBrush}"
            BorderBrush="{StaticResource BorderSubtleBrush}"
            BorderThickness="1"
            CornerRadius="10"
            Effect="{StaticResource WindowShadow}">

        <Grid x:Name="RootGrid">
            <Grid.RowDefinitions>
                <RowDefinition Height="38"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ══ TITLE BAR ══ -->
            <Grid Grid.Row="0"
                  Background="{StaticResource BgSecondaryBrush}"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- App name -->
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="14,0,0,0">
                    <Image Source="Assets/banners and icons/emutastic-logo.png"
                           Width="20" Height="20"
                           VerticalAlignment="Center"
                           Margin="0,0,7,0"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="Emutastic"
                               FontFamily="{StaticResource PrimaryFont}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Drag zone -->
                <Rectangle Grid.Column="1" Fill="Transparent"/>

                <!-- Window buttons -->
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,10,0">
                    <Button x:Name="MinimizeButton"
                            Width="13" Height="13"
                            Margin="0,0,6,0"
                            Cursor="Hand"
                            Click="MinimizeButton_Click"
                            ToolTip="Minimize">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Ellipse x:Name="circle" Fill="#FEBC2E"/>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="circle" Property="Fill" Value="#E5A800"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button x:Name="MaximizeButton"
                            Width="13" Height="13"
                            Margin="0,0,6,0"
                            Cursor="Hand"
                            Click="MaximizeButton_Click"
                            ToolTip="Maximize">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Ellipse x:Name="circle" Fill="#28C840"/>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="circle" Property="Fill" Value="#1FA832"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button x:Name="CloseButton"
                            Width="13" Height="13"
                            Cursor="Hand"
                            Click="CloseButton_Click"
                            ToolTip="Close">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Ellipse x:Name="circle" Fill="#FF5F57"/>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="circle" Property="Fill" Value="#E5453D"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- ══ BODY ══ -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ── SIDEBAR ── -->
                <Border Grid.Column="0"
                        Background="{StaticResource BgSecondaryBrush}"
                        BorderBrush="{StaticResource BorderSubtleBrush}"
                        BorderThickness="0,1,1,0">
                    <ScrollViewer Style="{StaticResource MinimalScrollViewer}"
                                  VerticalScrollBarVisibility="Auto"
                                  Padding="0,8,0,8">
                        <StackPanel x:Name="SidebarPanel">

                            <!-- Library -->
                            <TextBlock Text="LIBRARY"
                                       Style="{StaticResource LabelMuted}"
                                       Margin="16,10,0,4"/>
                            <Button Style="{StaticResource SidebarItemStyle}"
                                    x:Name="NavAllGames"
                                    Click="NavAllGames_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⊞  All Games" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="SidebarGameCount"
                                               Text="{Binding GameCountText}"
                                               FontSize="10"
                                               Foreground="#888888"
                                               VerticalAlignment="Center"
                                               Margin="6,0,0,0"/>
                                </StackPanel>
                            </Button>
                            <Button Content="◷  Recently Played"
                                    Style="{StaticResource SidebarItemStyle}"
                                    Click="NavRecent_Click"/>
                            <Button Content="♡  Favorites"
                                    Style="{StaticResource SidebarItemStyle}"
                                    Click="NavFavorites_Click"/>

                            <Rectangle Height="1"
                                       Fill="{StaticResource BorderSubtleBrush}"
                                       Margin="12,8"/>

                            <!-- Consoles -->
                            <TextBlock Text="CONSOLES"
                                       Style="{StaticResource LabelMuted}"
                                       Margin="16,4,0,4"/>

                            <!-- Atari -->
                            <Button Style="{StaticResource SidebarItemStyle}"
                                    Click="ToggleSection_Click"
                                    Tag="AtariSection"
                                    Margin="6,4,6,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="AtariArrow" Text="▾" FontSize="10" Margin="0,0,6,0"
                                               Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Text="ATARI" Style="{StaticResource LabelMuted}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <StackPanel x:Name="AtariSection">
                                <Button Content="🎮  Atari 2600"   Style="{StaticResource SidebarItemStyle}" Click="NavConsole_Click" Tag="Atari2600"/>
                                <Button Content="🎮  Atari 5200"   Style="{StaticResource SidebarItemStyle}" Click="NavConsole_Click" Tag="Atari5200"/>
                                <Button Content="🎮  Atari 7800"   Style="{StaticResource SidebarItemStyle}" Click="NavConsole_Click" Tag="Atari7800"/>
                                <Button Content="🎮  Atari Jaguar" Style="{StaticResource SidebarItemStyle}" Click="NavConsole_Click" Tag="Jaguar"/>
                            </StackPanel>

                            <!-- Nintendo -->
                            <Button Style="{StaticResource SidebarItemStyle}"
                                    Click="ToggleSection_Click"
                                    Tag="NintendoSection"
                                    Margin="6,4,6,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="NintendoArrow" Text="▾" FontSize="10" Margin="0,0,6,0"
                                               Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Text="NINTENDO" Style="{StaticResource LabelMuted}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <StackPanel x:Name="NintendoSection">
                                <Button Content="🎮  Nintendo (NES)"      Style="{StaticResource SidebarItemStyle}" Click="NavConsole_Click" Tag="NES"/>
                                <Button Content="🎮  Famicom Disk System" Style="{StaticResource SidebarItemStyle}" Click="NavConsole_Click" Tag="FDS"/>
                                <Button Content="🎮  Super Nintendo"      Style="{StaticResource SidebarItemStyle}" Click="NavConsole_Click" Tag="SNES"/>
                                <Button Content="🎮  Nintendo 64"         Style="{StaticResource SidebarItemStyle}" Click="NavConsole_Click" Tag="N64"/>
                                <Button Content="🎮  GameCube"            Style="{StaticResource SidebarItemStyle}" Click="NavConsole_Click" Tag="GameCube"/>
                                <Button Content="🎮  Game Boy"            Style="{StaticResource SidebarItemStyle}" Click="NavConsole_Click" Tag="GB"/>
                                <Button Content="🎮  Game Boy Color"      Style="{StaticResource SidebarItemStyle}" Click="NavConsole_Click" Tag="GBC"/>
                                <Button Content="🎮  Game Boy Advance"    Style="{StaticResource SidebarItemStyle}" Click="NavConsole_Click" Tag="GBA"/>
                                <Button Content="🎮  Nintendo DS"         Style="{StaticResource SidebarItemStyle}" Click="NavConsole_Click" Tag="NDS"/>
                                <Button Content="🎮  Virtual Boy"         Style="{StaticResource SidebarItemStyle}" Click="NavConsole_Click" Tag="VirtualBoy"/>
                            </StackPanel>

                            <!-- Sega -->
                            <Button Style="{StaticResource SidebarItemStyle}"
                                    Click="ToggleSection_Click"
                                    Tag="SegaSection"
                                    Margin="6,4,6,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="SegaArrow" Text="▾" FontSize="10" Margin="0,0,6,0"
                                               Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Text="SEGA" Style="{StaticResource LabelMuted}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <StackPanel x:Name="SegaSection">
                                <Button Content="🎮  Sega Master System" Style="{StaticResource SidebarItemStyle}" Click="NavConsole_Click" Tag="SMS"/>
                                <Button Content="🎮  Sega Genesis"       Style="{StaticResource SidebarItemStyle}" Click="NavConsole_Click" Tag="Genesis"/>
                                <Button Content="🎮  Sega CD"            Style="{StaticResource SidebarItemStyle}" Click="NavConsole_Click" Tag="SegaCD"/>
                                <Button Content="🎮  Sega 32X"           Style="{StaticResource SidebarItemStyle}" Click="NavConsole_Click" Tag="Sega32X"/>
                                <Button Content="🎮  Sega Saturn"        Style="{StaticResource SidebarItemStyle}" Click="NavConsole_Click" Tag="Saturn"/>
                                <Button Content="🎮  Sega Game Gear"     Style="{StaticResource SidebarItemStyle}" Click="NavConsole_Click" Tag="GameGear"/>
                                <Button Content="🎮  SG-1000"            Style="{StaticResource SidebarItemStyle}" Click="NavConsole_Click" Tag="SG1000"/>
                                <Button Content="🎮  Dreamcast"          Style="{StaticResource SidebarItemStyle}" Click="NavConsole_Click" Tag="Dreamcast"/>
                            </StackPanel>

                            <!-- Sony -->
                            <Button Style="{StaticResource SidebarItemStyle}"
                                    Click="ToggleSection_Click"
                                    Tag="SonySection"
                                    Margin="6,4,6,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="SonyArrow" Text="▾" FontSize="10" Margin="0,0,6,0"
                                               Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Text="SONY" Style="{StaticResource LabelMuted}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <StackPanel x:Name="SonySection">
                                <Button Content="🎮  PlayStation" Style="{StaticResource SidebarItemStyle}" Click="NavConsole_Click" Tag="PS1"/>
                                <Button Content="🎮  PSP"         Style="{StaticResource SidebarItemStyle}" Click="NavConsole_Click" Tag="PSP"/>
                            </StackPanel>

                            <!-- NEC -->
                            <Button Style="{StaticResource SidebarItemStyle}"
                                    Click="ToggleSection_Click"
                                    Tag="NECSection"
                                    Margin="6,4,6,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="NECArrow" Text="▾" FontSize="10" Margin="0,0,6,0"
                                               Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Text="NEC" Style="{StaticResource LabelMuted}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <StackPanel x:Name="NECSection">
                                <Button Content="🎮  TurboGrafx-16" Style="{StaticResource SidebarItemStyle}" Click="NavConsole_Click" Tag="TG16"/>
                                <Button Content="🎮  TurboGrafx-CD" Style="{StaticResource SidebarItemStyle}" Click="NavConsole_Click" Tag="TGCD"/>
                            </StackPanel>

                            <!-- SNK -->
                            <Button Style="{StaticResource SidebarItemStyle}"
                                    Click="ToggleSection_Click"
                                    Tag="SNKSection"
                                    Margin="6,4,6,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="SNKArrow" Text="▾" FontSize="10" Margin="0,0,6,0"
                                               Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Text="SNK" Style="{StaticResource LabelMuted}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <StackPanel x:Name="SNKSection">
                                <Button Content="🎮  NeoGeo Pocket" Style="{StaticResource SidebarItemStyle}" Click="NavConsole_Click" Tag="NGP"/>
                            </StackPanel>

                            <!-- Other -->
                            <Button Style="{StaticResource SidebarItemStyle}"
                                    Click="ToggleSection_Click"
                                    Tag="OtherSection"
                                    Margin="6,4,6,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="OtherArrow" Text="▾" FontSize="10" Margin="0,0,6,0"
                                               Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Text="OTHER" Style="{StaticResource LabelMuted}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <StackPanel x:Name="OtherSection">
                                <Button Content="🎮  3DO"           Style="{StaticResource SidebarItemStyle}" Click="NavConsole_Click" Tag="3DO"/>
                                <Button Content="🎮  ColecoVision"  Style="{StaticResource SidebarItemStyle}" Click="NavConsole_Click" Tag="ColecoVision"/>
                                <Button Content="🎮  Intellivision" Style="{StaticResource SidebarItemStyle}" Click="NavConsole_Click" Tag="Intellivision"/>
                                <Button Content="🎮  Vectrex"       Style="{StaticResource SidebarItemStyle}" Click="NavConsole_Click" Tag="Vectrex"/>
                            </StackPanel>

                            <Rectangle Height="1"
                                       Fill="{StaticResource BorderSubtleBrush}"
                                       Margin="12,8"/>

                            <!-- Collections -->
                            <TextBlock Text="COLLECTIONS"
                                       Style="{StaticResource LabelMuted}"
                                       Margin="16,4,0,4"/>
                            <Button Content="⊞  All Games"
                                    Style="{StaticResource SidebarItemStyle}"
                                    Click="NavAllGames_Click"/>
                            <Button Content="🕐  Recently Added"
                                    Style="{StaticResource SidebarItemStyle}"
                                    Click="NavRecentlyAdded_Click"/>
                            <!-- User-created collections injected here at runtime -->
                            <StackPanel x:Name="UserCollectionsPanel"/>

                            <!-- Options -->
                            <TextBlock Text="OPTIONS"
                                       Style="{StaticResource LabelMuted}"
                                       Margin="16,4,0,4"/>
                            <Button Content="⚙  Preferences"
                                    Style="{StaticResource SidebarItemStyle}"
                                    Click="NavPreferences_Click"/>
                            <Button Content="↓  Import ROMs"
                                    Style="{StaticResource SidebarItemStyle}"
                                    Click="NavImport_Click"/>

                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- ── CONTENT AREA ── -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="44"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Toolbar -->
                    <Border Grid.Row="0"
                            Background="{StaticResource BgSecondaryBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}"
                            BorderThickness="0,1,0,1">
                        <!-- Three-column grid: Auto | * | Auto guarantees true centering of the nav buttons -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- LEFT: grid/list view toggle -->
                            <Border Grid.Column="0"
                                    Background="#1E1E1E"
                                    CornerRadius="10"
                                    BorderThickness="0"
                                    VerticalAlignment="Center"
                                    Margin="12,0,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <ToggleButton x:Name="ViewGrid"
                                                  Style="{StaticResource ViewGridStyle}"
                                                  IsChecked="True"
                                                  Click="ViewToggle_Click"
                                                  Tag="Grid"/>
                                    <ToggleButton x:Name="ViewList"
                                                  Style="{StaticResource ViewListStyle}"
                                                  Click="ViewToggle_Click"
                                                  Tag="List"/>
                                </StackPanel>
                            </Border>

                            <!-- CENTER: Library / Save States nav, truly centered -->
                            <Border Grid.Column="1"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Background="#1E1E1E"
                                    CornerRadius="10"
                                    BorderThickness="0">
                                <StackPanel Orientation="Horizontal">
                                    <ToggleButton x:Name="TabLibrary"
                                                  Content="Library"
                                                  Style="{StaticResource TabToggleLeftStyle}"
                                                  Click="Tab_Click"
                                                  Tag="Library"/>
                                    <ToggleButton x:Name="TabSaveStates"
                                                  Content="Save States"
                                                  Style="{StaticResource TabToggleRightStyle}"
                                                  Click="Tab_Click"
                                                  Tag="SaveStates"/>
                                </StackPanel>
                            </Border>

                            <!-- RIGHT: search bar -->
                            <Border Grid.Column="2"
                                    Background="{StaticResource BgTertiaryBrush}"
                                    BorderBrush="{StaticResource BorderSubtleBrush}"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Padding="10,0"
                                    Width="180"
                                    Height="26"
                                    VerticalAlignment="Center"
                                    Margin="0,0,12,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="⌕"
                                               FontSize="13"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,6,0"/>
                                    <TextBox Grid.Column="1"
                                             x:Name="SearchBox"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Foreground="{StaticResource TextPrimaryBrush}"
                                             CaretBrush="{StaticResource AccentBrush}"
                                             FontFamily="{StaticResource PrimaryFont}"
                                             FontSize="12"
                                             VerticalAlignment="Center"
                                             TextChanged="SearchBox_TextChanged">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox">
                                                <Style.Triggers>
                                                    <Trigger Property="Text" Value="">
                                                        <Setter Property="Background">
                                                            <Setter.Value>
                                                                <VisualBrush Stretch="None" AlignmentX="Left">
                                                                    <VisualBrush.Visual>
                                                                        <TextBlock Text="Search games…"
                                                                                   Foreground="{StaticResource TextMutedBrush}"
                                                                                   FontFamily="{StaticResource PrimaryFont}"
                                                                                   FontSize="12"/>
                                                                    </VisualBrush.Visual>
                                                                </VisualBrush>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                </Grid>
                            </Border>

                            <!-- Hidden; kept for code-behind compat (artwork fetch status, etc.) -->
                            <TextBlock x:Name="ToolbarTitle" Visibility="Collapsed"/>
                        </Grid>
                    </Border>

                    <!-- Game grid (Library view) -->
                    <ScrollViewer x:Name="LibraryView"
                                  Grid.Row="1"
                                  Style="{StaticResource MinimalScrollViewer}"
                                  VerticalScrollBarVisibility="Auto"
                                  Padding="16">
                        <StackPanel>


                            <!-- Game cards (grid view) -->
                            <ItemsControl x:Name="GameGridView"
                                          ItemsSource="{Binding Games}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="148"
                                                Margin="0,0,12,12"
                                                CornerRadius="8"
                                                ClipToBounds="True"
                                                Cursor="Hand"
                                                MouseLeftButtonDown="GameCard_Click"
                                                MouseRightButtonDown="GameCard_RightClick">
                                            <Border.Background>
                                                <SolidColorBrush Color="{Binding BackgroundColor, Converter={StaticResource StringToColor}}"/>
                                            </Border.Background>
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Effect">
                                                                <Setter.Value>
                                                                    <DropShadowEffect BlurRadius="16"
                                                                                      ShadowDepth="4"
                                                                                      Opacity="0.5"
                                                                                      Color="#000000"/>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel>
                                                <!-- Art area -->
                                                <Border Height="180" ClipToBounds="True">
                                                    <Border.Background>
                                                        <SolidColorBrush Color="{Binding BackgroundColor, Converter={StaticResource StringToColor}}"/>
                                                    </Border.Background>
                                                    <Grid>
                                                        <!-- Colored placeholder shown when no artwork -->
                                                        <Border>
                                                            <Border.Background>
                                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                                    <GradientStop Color="#33FFFFFF" Offset="0"/>
                                                                    <GradientStop Color="#00FFFFFF" Offset="1"/>
                                                                </LinearGradientBrush>
                                                            </Border.Background>
                                                        </Border>

                                                        <!-- Placeholder title text — hidden when artwork exists -->
                                                        <TextBlock Text="{Binding Title}"
                   FontFamily="{StaticResource PrimaryFont}"
                   FontSize="13"
                   FontWeight="SemiBold"
                   Foreground="#CCFFFFFF"
                   TextWrapping="Wrap"
                   TextAlignment="Center"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center"
                   Margin="12"
                   Visibility="{Binding CoverArtPath,
                       Converter={StaticResource NullToVisibility}}"/>

                                                        <!-- Actual box art image -->
                                                        <Image Source="{Binding CoverArtPath, Converter={StaticResource PathToImage}}"
       Stretch="UniformToFill"
       Visibility="{Binding CoverArtPath,
           Converter={StaticResource NotNullToVisibility}}"/>

                                                        <!-- Favorite heart -->
                                                        <TextBlock Text="♥"
                   FontSize="14"
                   Foreground="#FFFF6B6B"
                   VerticalAlignment="Top"
                   HorizontalAlignment="Right"
                   Margin="0,8,8,0"
                   Visibility="{Binding IsFavorite,
                       Converter={StaticResource BoolToVisibility}}"/>
                                                    </Grid>
                                                </Border>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Game list (list view) -->
                            <ItemsControl x:Name="GameListView"
                                          ItemsSource="{Binding Games}"
                                          Visibility="Collapsed">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="8,6"
                                                Cursor="Hand"
                                                MouseLeftButtonDown="GameCard_Click"
                                                MouseRightButtonDown="GameCard_RightClick">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource BgTertiaryBrush}"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="48"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0"
                                                        Width="44" Height="44"
                                                        CornerRadius="4"
                                                        ClipToBounds="True">
                                                    <Border.Background>
                                                        <SolidColorBrush Color="{Binding BackgroundColor, Converter={StaticResource StringToColor}}"/>
                                                    </Border.Background>
                                                    <Image Source="{Binding CoverArtPath, Converter={StaticResource PathToImage}}"
                                                           Stretch="UniformToFill"
                                                           Visibility="{Binding CoverArtPath, Converter={StaticResource NotNullToVisibility}}"/>
                                                </Border>
                                                <StackPanel Grid.Column="1"
                                                            VerticalAlignment="Center"
                                                            Margin="10,0,0,0">
                                                    <TextBlock Text="{Binding Title}"
                                                               FontFamily="{StaticResource PrimaryFont}"
                                                               FontSize="13"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                                    <TextBlock Text="{Binding Console}"
                                                               FontFamily="{StaticResource PrimaryFont}"
                                                               FontSize="11"
                                                               Foreground="{StaticResource TextMutedBrush}"
                                                               Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Empty state -->
                            <StackPanel HorizontalAlignment="Center"
                                        Margin="0,80,0,0"
                                        Visibility="{Binding Games.Count,
                                            Converter={StaticResource CountToVisibility}}">
                                <TextBlock Text="🕹"
                                           FontSize="48"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="No games here yet"
                                           FontFamily="{StaticResource PrimaryFont}"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center"
                                           Margin="0,12,0,0"/>
                                <TextBlock Text="Drop ROM files anywhere to import them"
                                           FontFamily="{StaticResource PrimaryFont}"
                                           FontSize="13"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           HorizontalAlignment="Center"
                                           Margin="0,6,0,0"/>
                            </StackPanel>

                        </StackPanel>
                    </ScrollViewer>

                    <!-- Save States view -->
                    <ScrollViewer x:Name="SaveStatesView"
                                  Grid.Row="1"
                                  Visibility="Collapsed"
                                  Style="{StaticResource MinimalScrollViewer}"
                                  VerticalScrollBarVisibility="Auto"
                                  Padding="16">
                        <StackPanel>
                            <TextBlock x:Name="SaveStatesEmptyText"
                                       Text="No save states yet. Press F5 or the Save State button while in a game."
                                       FontFamily="{StaticResource PrimaryFont}"
                                       FontSize="13"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       HorizontalAlignment="Center"
                                       Margin="0,60,0,0"
                                       Visibility="Collapsed"/>
                            <StackPanel x:Name="SaveStatesPanel"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

            </Grid>

            <!-- ── DROP OVERLAY ── -->
            <Border x:Name="DropOverlay"
                    Grid.RowSpan="2"
                    Visibility="Collapsed"
                    Background="#CC0F0F10"
                    CornerRadius="10">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <Border Width="160" Height="160"
                            BorderBrush="{StaticResource AccentBrush}"
                            BorderThickness="2"
                            CornerRadius="80">
                        <TextBlock Text="🕹"
                                   FontSize="52"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Drop ROMs to Import"
                               FontFamily="{StaticResource PrimaryFont}"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,20,0,0"/>
                    <TextBlock Text="Supports all major console formats"
                               FontFamily="{StaticResource PrimaryFont}"
                               FontSize="13"
                               Foreground="{StaticResource TextMutedBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

        </Grid>
    </Border>
</Window>