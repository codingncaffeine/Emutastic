<Window x:Class="Emutastic.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Emutastic"
        xmlns:converters="clr-namespace:Emutastic.Converters"
        xmlns:vwp="clr-namespace:WpfToolkit.Controls;assembly=VirtualizingWrapPanel"
        mc:Ignorable="d"
        Title="Emutastic"
        Height="720" Width="1100"
        MinHeight="500" MinWidth="800"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Window.Resources>
        <!-- Proxy that lets MultiBinding consume the LibraryCardWidth DynamicResource -->
        <converters:BindingProxy x:Key="CardWidthProxy" Data="{DynamicResource LibraryCardWidth}"/>

        <DropShadowEffect x:Key="WindowShadow"
                          BlurRadius="30"
                          ShadowDepth="0"
                          Opacity="0.6"
                          Color="#000000"/>

        <!-- Shared trigger logic extracted via a base style is not possible with ControlTemplate,
             so Left and Right caps are defined as two complete styles. -->

        <Style x:Key="TabToggleLeftStyle" TargetType="ToggleButton">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Padding"    Value="12,6"/>
            <Setter Property="Cursor"     Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="pill"
                                Background="#2D2D2D"
                                BorderBrush="#1A1A1A"
                                BorderThickness="1,1,1,1"
                                CornerRadius="10,0,0,10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="#E0E0E0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="pill" Property="Background" Value="#555555"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked"   Value="False"/>
                                </MultiTrigger.Conditions>
                                <MultiTrigger.Setters>
                                    <Setter TargetName="pill" Property="Background" Value="#3D3D3D"/>
                                </MultiTrigger.Setters>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TabToggleMiddleStyle" TargetType="ToggleButton">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Padding"    Value="12,6"/>
            <Setter Property="Cursor"     Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="pill"
                                Background="#2D2D2D"
                                BorderBrush="#1A1A1A"
                                BorderThickness="0,1,0,1"
                                CornerRadius="0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="#E0E0E0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="pill" Property="Background" Value="#555555"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked"   Value="False"/>
                                </MultiTrigger.Conditions>
                                <MultiTrigger.Setters>
                                    <Setter TargetName="pill" Property="Background" Value="#3D3D3D"/>
                                </MultiTrigger.Setters>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TabToggleRightStyle" TargetType="ToggleButton">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Padding"    Value="12,6"/>
            <Setter Property="Cursor"     Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="pill"
                                Background="#2D2D2D"
                                BorderBrush="#1A1A1A"
                                BorderThickness="0,1,1,1"
                                CornerRadius="0,10,10,0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="#E0E0E0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="pill" Property="Background" Value="#555555"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked"   Value="False"/>
                                </MultiTrigger.Conditions>
                                <MultiTrigger.Setters>
                                    <Setter TargetName="pill" Property="Background" Value="#3D3D3D"/>
                                </MultiTrigger.Setters>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ViewGridStyle" TargetType="ToggleButton">
            <Setter Property="Width"  Value="32"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment"   Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="pill"
                                Background="#2D2D2D"
                                BorderBrush="#1A1A1A"
                                BorderThickness="1,1,1,1"
                                CornerRadius="10,0,0,10">
                            <Viewbox Width="14" Height="14" Stretch="Uniform"
                                     HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Canvas Width="14" Height="14">
                                    <Rectangle x:Name="G1" Canvas.Left="0" Canvas.Top="0" Width="6" Height="6" Fill="#E0E0E0"/>
                                    <Rectangle x:Name="G2" Canvas.Left="8" Canvas.Top="0" Width="6" Height="6" Fill="#E0E0E0"/>
                                    <Rectangle x:Name="G3" Canvas.Left="0" Canvas.Top="8" Width="6" Height="6" Fill="#E0E0E0"/>
                                    <Rectangle x:Name="G4" Canvas.Left="8" Canvas.Top="8" Width="6" Height="6" Fill="#E0E0E0"/>
                                </Canvas>
                            </Viewbox>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="pill" Property="Background" Value="#555555"/>
                                <Setter TargetName="G1"   Property="Fill"       Value="#E0E0E0"/>
                                <Setter TargetName="G2"   Property="Fill"       Value="#E0E0E0"/>
                                <Setter TargetName="G3"   Property="Fill"       Value="#E0E0E0"/>
                                <Setter TargetName="G4"   Property="Fill"       Value="#E0E0E0"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked"   Value="False"/>
                                </MultiTrigger.Conditions>
                                <MultiTrigger.Setters>
                                    <Setter TargetName="pill" Property="Background" Value="#3D3D3D"/>
                                </MultiTrigger.Setters>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ViewListStyle" TargetType="ToggleButton">
            <Setter Property="Width"  Value="32"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment"   Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="pill"
                                Background="#2D2D2D"
                                BorderBrush="#1A1A1A"
                                BorderThickness="0,1,1,1"
                                CornerRadius="0,10,10,0">
                            <Viewbox Width="14" Height="14" Stretch="Uniform"
                                     HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Canvas Width="14" Height="14">
                                    <Rectangle x:Name="L1" Canvas.Left="0" Canvas.Top="0"   Width="14" Height="3" Fill="#E0E0E0"/>
                                    <Rectangle x:Name="L2" Canvas.Left="0" Canvas.Top="5.5" Width="14" Height="3" Fill="#E0E0E0"/>
                                    <Rectangle x:Name="L3" Canvas.Left="0" Canvas.Top="11"  Width="14" Height="3" Fill="#E0E0E0"/>
                                </Canvas>
                            </Viewbox>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="pill" Property="Background" Value="#555555"/>
                                <Setter TargetName="L1"   Property="Fill"       Value="#E0E0E0"/>
                                <Setter TargetName="L2"   Property="Fill"       Value="#E0E0E0"/>
                                <Setter TargetName="L3"   Property="Fill"       Value="#E0E0E0"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked"   Value="False"/>
                                </MultiTrigger.Conditions>
                                <MultiTrigger.Setters>
                                    <Setter TargetName="pill" Property="Background" Value="#3D3D3D"/>
                                </MultiTrigger.Setters>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Border x:Name="OuterBorder"
            Background="{StaticResource BgPrimaryBrush}"
            BorderBrush="{StaticResource BorderSubtleBrush}"
            BorderThickness="1"
            CornerRadius="10"
            Effect="{StaticResource WindowShadow}">

        <Grid x:Name="RootGrid">
            <Grid.RowDefinitions>
                <RowDefinition Height="38"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ══ TITLE BAR ══ -->
            <Grid x:Name="CustomTitleBar"
                  Grid.Row="0"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left: transparent strip aligned with sidebar -->
                <Border Grid.Column="0" Background="#B3181819">
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="14,0,0,0">
                        <Image Source="Assets/banners and icons/emutastic-logo.png"
                               Width="20" Height="20"
                               VerticalAlignment="Center"
                               Margin="0,0,7,0"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock Text="Emutastic"
                                   FontFamily="{StaticResource PrimaryFont}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Right: normal title bar with drag zone + window buttons -->
                <Grid Grid.Column="1" Background="{StaticResource BgSecondaryBrush}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Drag zone + status text -->
                    <Grid Grid.Column="0">
                        <Rectangle Fill="Transparent"/>
                        <TextBlock x:Name="StatusText"
                                   Text=""
                                   FontFamily="{StaticResource PrimaryFont}"
                                   FontSize="11"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False"/>
                    </Grid>

                    <!-- Window buttons -->
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="0,0,10,0">
                        <Button x:Name="MinimizeButton"
                                Width="13" Height="13"
                                Margin="0,0,6,0"
                                Cursor="Hand"
                                Click="MinimizeButton_Click"
                                ToolTip="Minimize">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Ellipse x:Name="circle" Fill="#FEBC2E"/>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="circle" Property="Fill" Value="#E5A800"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button x:Name="MaximizeButton"
                                Width="13" Height="13"
                                Margin="0,0,6,0"
                                Cursor="Hand"
                                Click="MaximizeButton_Click"
                                ToolTip="Maximize">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Ellipse x:Name="circle" Fill="#28C840"/>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="circle" Property="Fill" Value="#1FA832"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button x:Name="CloseButton"
                                Width="13" Height="13"
                                Cursor="Hand"
                                Click="CloseButton_Click"
                                ToolTip="Close">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Ellipse x:Name="circle" Fill="#FF5F57"/>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="circle" Property="Fill" Value="#E5453D"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>

            <!-- ══ BODY ══ -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ── SIDEBAR ── -->
                <Border Grid.Column="0"
                        Background="#B3181819"
                        BorderBrush="{StaticResource BorderSubtleBrush}"
                        BorderThickness="0,1,1,0">
                    <ScrollViewer Style="{StaticResource MinimalScrollViewer}"
                                  VerticalScrollBarVisibility="Auto"
                                  Padding="0,8,0,8">
                        <StackPanel x:Name="SidebarPanel"
                                    MouseRightButtonUp="SidebarPanel_RightClick">

                            <!-- Library -->
                            <TextBlock Text="LIBRARY"
                                       Style="{StaticResource LabelMuted}"
                                       Margin="16,10,0,4"/>
                            <Button Style="{StaticResource SidebarItemStyle}"
                                    x:Name="NavAllGames"
                                    Click="NavAllGames_Click"
                                    Visibility="Collapsed"/>
                            <Button Content="◷  Recently Played"
                                    Style="{StaticResource SidebarItemStyle}"
                                    Click="NavRecent_Click"/>
                            <Button Content="♡  Favorites"
                                    Style="{StaticResource SidebarItemStyle}"
                                    Click="NavFavorites_Click"/>

                            <Rectangle Height="1"
                                       Fill="{StaticResource BorderSubtleBrush}"
                                       Margin="12,8"/>

                            <!-- Consoles -->
                            <TextBlock Text="CONSOLES"
                                       Style="{StaticResource LabelMuted}"
                                       Margin="16,4,0,4"/>

                            <Button Style="{StaticResource SidebarItemStyle}" Click="NavConsole_Click" Tag="Arcade">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🕹" FontSize="16" Width="20" TextAlignment="Center" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="Arcade" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Atari -->
                            <Button Style="{StaticResource SidebarItemStyle}"
                                    Click="ToggleSection_Click"
                                    Tag="AtariSection"
                                    Margin="6,4,6,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="AtariArrow" Text="▾" FontSize="10" Margin="0,0,6,0"
                                               Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Text="ATARI" Style="{StaticResource LabelMuted}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <StackPanel x:Name="AtariSection">
                                <Button Style="{StaticResource SidebarItemStyle}" Click="NavConsole_Click" Tag="Atari2600"><StackPanel Orientation="Horizontal"><Image Source="Assets/system_icons/atari2600.jpg"        Width="20" Height="20" Margin="0,0,8,0" RenderOptions.BitmapScalingMode="HighQuality"/><TextBlock Text="Atari 2600"   VerticalAlignment="Center"/></StackPanel></Button>

                                <Button Style="{StaticResource SidebarItemStyle}" Click="NavConsole_Click" Tag="Atari7800"><StackPanel Orientation="Horizontal"><Image Source="Assets/system_icons/atari7800.jpg"        Width="20" Height="20" Margin="0,0,8,0" RenderOptions.BitmapScalingMode="HighQuality"/><TextBlock Text="Atari 7800"   VerticalAlignment="Center"/></StackPanel></Button>
                                <Button Style="{StaticResource SidebarItemStyle}" Click="NavConsole_Click" Tag="Jaguar">  <StackPanel Orientation="Horizontal"><Image Source="Assets/system_icons/systemicons1_13.jpg" Width="20" Height="20" Margin="0,0,8,0" RenderOptions.BitmapScalingMode="HighQuality"/><TextBlock Text="Atari Jaguar" VerticalAlignment="Center"/></StackPanel></Button>
                            </StackPanel>

                            <!-- Nintendo -->
                            <Button Style="{StaticResource SidebarItemStyle}"
                                    Click="ToggleSection_Click"
                                    Tag="NintendoSection"
                                    Margin="6,4,6,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="NintendoArrow" Text="▾" FontSize="10" Margin="0,0,6,0"
                                               Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Text="NINTENDO" Style="{StaticResource LabelMuted}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <StackPanel x:Name="NintendoSection">
                                <Button Style="{StaticResource SidebarItemStyle}" Click="NavConsole_Click" Tag="NES">      <StackPanel Orientation="Horizontal"><Image Source="Assets/system_icons/nes_icon.jpg"              Width="20" Height="20" Margin="0,0,8,0" RenderOptions.BitmapScalingMode="HighQuality"/><TextBlock Text="Nintendo (NES)"      VerticalAlignment="Center"/></StackPanel></Button>
                                <Button Style="{StaticResource SidebarItemStyle}" Click="NavConsole_Click" Tag="FDS">      <StackPanel Orientation="Horizontal"><Image Source="Assets/system_icons/famicon disk system.jpg"    Width="20" Height="20" Margin="0,0,8,0" RenderOptions.BitmapScalingMode="HighQuality"/><TextBlock Text="Famicom Disk System" VerticalAlignment="Center"/></StackPanel></Button>
                                <Button Style="{StaticResource SidebarItemStyle}" Click="NavConsole_Click" Tag="SNES">     <StackPanel Orientation="Horizontal"><Image Source="Assets/system_icons/snes.jpg"                   Width="20" Height="20" Margin="0,0,8,0" RenderOptions.BitmapScalingMode="HighQuality"/><TextBlock Text="Super Nintendo"      VerticalAlignment="Center"/></StackPanel></Button>
                                <Button Style="{StaticResource SidebarItemStyle}" Click="NavConsole_Click" Tag="N64">      <StackPanel Orientation="Horizontal"><Image Source="Assets/system_icons/n64.jpg"                    Width="20" Height="20" Margin="0,0,8,0" RenderOptions.BitmapScalingMode="HighQuality"/><TextBlock Text="Nintendo 64"         VerticalAlignment="Center"/></StackPanel></Button>
                                <Button Style="{StaticResource SidebarItemStyle}" Click="NavConsole_Click" Tag="GameCube"> <StackPanel Orientation="Horizontal"><Image Source="Assets/system_icons/gamecube.jpg"               Width="20" Height="20" Margin="0,0,8,0" RenderOptions.BitmapScalingMode="HighQuality"/><TextBlock Text="GameCube"            VerticalAlignment="Center"/></StackPanel></Button>
                                <Button Style="{StaticResource SidebarItemStyle}" Click="NavConsole_Click" Tag="GB">       <StackPanel Orientation="Horizontal"><Image Source="Assets/system_icons/gameboy.jpg"               Width="20" Height="20" Margin="0,0,8,0" RenderOptions.BitmapScalingMode="HighQuality"/><TextBlock Text="Game Boy"            VerticalAlignment="Center"/></StackPanel></Button>
                                <Button Style="{StaticResource SidebarItemStyle}" Click="NavConsole_Click" Tag="GBC">      <StackPanel Orientation="Horizontal"><Image Source="Assets/system_icons/gameboy.jpg"               Width="20" Height="20" Margin="0,0,8,0" RenderOptions.BitmapScalingMode="HighQuality"/><TextBlock Text="Game Boy Color"      VerticalAlignment="Center"/></StackPanel></Button>
                                <Button Style="{StaticResource SidebarItemStyle}" Click="NavConsole_Click" Tag="GBA">      <StackPanel Orientation="Horizontal"><Image Source="Assets/system_icons/gba.jpg"                   Width="20" Height="20" Margin="0,0,8,0" RenderOptions.BitmapScalingMode="HighQuality"/><TextBlock Text="Game Boy Advance"    VerticalAlignment="Center"/></StackPanel></Button>
                                <Button Style="{StaticResource SidebarItemStyle}" Click="NavConsole_Click" Tag="NDS">      <StackPanel Orientation="Horizontal"><Image Source="Assets/system_icons/nds.jpg"                   Width="20" Height="20" Margin="0,0,8,0" RenderOptions.BitmapScalingMode="HighQuality"/><TextBlock Text="Nintendo DS"         VerticalAlignment="Center"/></StackPanel></Button>
                                <Button Style="{StaticResource SidebarItemStyle}" Click="NavConsole_Click" Tag="VirtualBoy"><StackPanel Orientation="Horizontal"><Image Source="Assets/system_icons/virtualboy.jpg"           Width="20" Height="20" Margin="0,0,8,0" RenderOptions.BitmapScalingMode="HighQuality"/><TextBlock Text="Virtual Boy"         VerticalAlignment="Center"/></StackPanel></Button>
                            </StackPanel>

                            <!-- Sega -->
                            <Button Style="{StaticResource SidebarItemStyle}"
                                    Click="ToggleSection_Click"
                                    Tag="SegaSection"
                                    Margin="6,4,6,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="SegaArrow" Text="▾" FontSize="10" Margin="0,0,6,0"
                                               Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Text="SEGA" Style="{StaticResource LabelMuted}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <StackPanel x:Name="SegaSection">
                                <Button Style="{StaticResource SidebarItemStyle}" Click="NavConsole_Click" Tag="SMS">      <StackPanel Orientation="Horizontal"><Image Source="Assets/system_icons/sms.jpg"       Width="20" Height="20" Margin="0,0,8,0" RenderOptions.BitmapScalingMode="HighQuality"/><TextBlock Text="Sega Master System" VerticalAlignment="Center"/></StackPanel></Button>
                                <Button Style="{StaticResource SidebarItemStyle}" Click="NavConsole_Click" Tag="Genesis">  <StackPanel Orientation="Horizontal"><Image Source="Assets/system_icons/genesis.jpg"   Width="20" Height="20" Margin="0,0,8,0" RenderOptions.BitmapScalingMode="HighQuality"/><TextBlock Text="Sega Genesis"       VerticalAlignment="Center"/></StackPanel></Button>
                                <Button Style="{StaticResource SidebarItemStyle}" Click="NavConsole_Click" Tag="SegaCD">   <StackPanel Orientation="Horizontal"><Image Source="Assets/system_icons/genesis.jpg"   Width="20" Height="20" Margin="0,0,8,0" RenderOptions.BitmapScalingMode="HighQuality"/><TextBlock Text="Sega CD"            VerticalAlignment="Center"/></StackPanel></Button>
                                <Button Style="{StaticResource SidebarItemStyle}" Click="NavConsole_Click" Tag="Sega32X">  <StackPanel Orientation="Horizontal"><Image Source="Assets/system_icons/32x.jpg"       Width="20" Height="20" Margin="0,0,8,0" RenderOptions.BitmapScalingMode="HighQuality"/><TextBlock Text="Sega 32X"           VerticalAlignment="Center"/></StackPanel></Button>
                                <Button Style="{StaticResource SidebarItemStyle}" Click="NavConsole_Click" Tag="Saturn">   <StackPanel Orientation="Horizontal"><Image Source="Assets/system_icons/saturn.jpg"    Width="20" Height="20" Margin="0,0,8,0" RenderOptions.BitmapScalingMode="HighQuality"/><TextBlock Text="Sega Saturn"        VerticalAlignment="Center"/></StackPanel></Button>
                                <Button Style="{StaticResource SidebarItemStyle}" Click="NavConsole_Click" Tag="GameGear"> <StackPanel Orientation="Horizontal"><Image Source="Assets/system_icons/sms.jpg"       Width="20" Height="20" Margin="0,0,8,0" RenderOptions.BitmapScalingMode="HighQuality"/><TextBlock Text="Sega Game Gear"     VerticalAlignment="Center"/></StackPanel></Button>
                                <Button Style="{StaticResource SidebarItemStyle}" Click="NavConsole_Click" Tag="SG1000">   <StackPanel Orientation="Horizontal"><Image Source="Assets/system_icons/sms.jpg"       Width="20" Height="20" Margin="0,0,8,0" RenderOptions.BitmapScalingMode="HighQuality"/><TextBlock Text="SG-1000"            VerticalAlignment="Center"/></StackPanel></Button>
                                <Button Style="{StaticResource SidebarItemStyle}" Click="NavConsole_Click" Tag="Dreamcast"><StackPanel Orientation="Horizontal"><Image Source="Assets/system_icons/dreamcast.jpg" Width="20" Height="20" Margin="0,0,8,0" RenderOptions.BitmapScalingMode="HighQuality"/><TextBlock Text="Dreamcast"          VerticalAlignment="Center"/></StackPanel></Button>
                            </StackPanel>

                            <!-- Sony -->
                            <Button Style="{StaticResource SidebarItemStyle}"
                                    Click="ToggleSection_Click"
                                    Tag="SonySection"
                                    Margin="6,4,6,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="SonyArrow" Text="▾" FontSize="10" Margin="0,0,6,0"
                                               Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Text="SONY" Style="{StaticResource LabelMuted}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <StackPanel x:Name="SonySection">
                                <Button Style="{StaticResource SidebarItemStyle}" Click="NavConsole_Click" Tag="PS1"><StackPanel Orientation="Horizontal"><Image Source="Assets/system_icons/ps1.jpg" Width="20" Height="20" Margin="0,0,8,0" RenderOptions.BitmapScalingMode="HighQuality"/><TextBlock Text="PlayStation" VerticalAlignment="Center"/></StackPanel></Button>
                                <Button Style="{StaticResource SidebarItemStyle}" Click="NavConsole_Click" Tag="PSP"><StackPanel Orientation="Horizontal"><Image Source="Assets/system_icons/psp.jpg" Width="20" Height="20" Margin="0,0,8,0" RenderOptions.BitmapScalingMode="HighQuality"/><TextBlock Text="PSP"         VerticalAlignment="Center"/></StackPanel></Button>
                            </StackPanel>

                            <!-- NEC -->
                            <Button Style="{StaticResource SidebarItemStyle}"
                                    Click="ToggleSection_Click"
                                    Tag="NECSection"
                                    Margin="6,4,6,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="NECArrow" Text="▾" FontSize="10" Margin="0,0,6,0"
                                               Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Text="NEC" Style="{StaticResource LabelMuted}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <StackPanel x:Name="NECSection">
                                <Button Style="{StaticResource SidebarItemStyle}" Click="NavConsole_Click" Tag="TG16"><StackPanel Orientation="Horizontal"><Image Source="Assets/system_icons/TG16.jpg" Width="20" Height="20" Margin="0,0,8,0" RenderOptions.BitmapScalingMode="HighQuality"/><TextBlock Text="TurboGrafx-16" VerticalAlignment="Center"/></StackPanel></Button>
                                <Button Style="{StaticResource SidebarItemStyle}" Click="NavConsole_Click" Tag="TGCD"><StackPanel Orientation="Horizontal"><Image Source="Assets/system_icons/TG16.jpg" Width="20" Height="20" Margin="0,0,8,0" RenderOptions.BitmapScalingMode="HighQuality"/><TextBlock Text="TurboGrafx-CD" VerticalAlignment="Center"/></StackPanel></Button>
                            </StackPanel>

                            <!-- SNK -->
                            <Button Style="{StaticResource SidebarItemStyle}"
                                    Click="ToggleSection_Click"
                                    Tag="SNKSection"
                                    Margin="6,4,6,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="SNKArrow" Text="▾" FontSize="10" Margin="0,0,6,0"
                                               Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Text="SNK" Style="{StaticResource LabelMuted}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <StackPanel x:Name="SNKSection">
                                <Button Style="{StaticResource SidebarItemStyle}" Click="NavConsole_Click" Tag="NGP"><StackPanel Orientation="Horizontal"><Image Source="Assets/system_icons/neo geo pocket.jpg" Width="20" Height="20" Margin="0,0,8,0" RenderOptions.BitmapScalingMode="HighQuality"/><TextBlock Text="NeoGeo Pocket" VerticalAlignment="Center"/></StackPanel></Button>
                            </StackPanel>

                            <!-- Other -->
                            <Button Style="{StaticResource SidebarItemStyle}"
                                    Click="ToggleSection_Click"
                                    Tag="OtherSection"
                                    Margin="6,4,6,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="OtherArrow" Text="▾" FontSize="10" Margin="0,0,6,0"
                                               Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Text="OTHER" Style="{StaticResource LabelMuted}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <StackPanel x:Name="OtherSection">
                                <Button Style="{StaticResource SidebarItemStyle}" Click="NavConsole_Click" Tag="3DO">         <StackPanel Orientation="Horizontal"><Image Source="Assets/system_icons/3d0.jpg"          Width="20" Height="20" Margin="0,0,8,0" RenderOptions.BitmapScalingMode="HighQuality"/><TextBlock Text="3DO"           VerticalAlignment="Center"/></StackPanel></Button>
                                <Button Style="{StaticResource SidebarItemStyle}" Click="NavConsole_Click" Tag="ColecoVision"><StackPanel Orientation="Horizontal"><Image Source="Assets/system_icons/coleco.jpg"        Width="20" Height="20" Margin="0,0,8,0" RenderOptions.BitmapScalingMode="HighQuality"/><TextBlock Text="ColecoVision"  VerticalAlignment="Center"/></StackPanel></Button>

                                <Button Style="{StaticResource SidebarItemStyle}" Click="NavConsole_Click" Tag="Vectrex">     <StackPanel Orientation="Horizontal"><Image Source="Assets/system_icons/vectrex.jpg"       Width="20" Height="20" Margin="0,0,8,0" RenderOptions.BitmapScalingMode="HighQuality"/><TextBlock Text="Vectrex"       VerticalAlignment="Center"/></StackPanel></Button>
                            </StackPanel>

                            <Rectangle Height="1"
                                       Fill="{StaticResource BorderSubtleBrush}"
                                       Margin="12,8"/>

                            <!-- Collections -->
                            <TextBlock Text="COLLECTIONS"
                                       Style="{StaticResource LabelMuted}"
                                       Margin="16,4,0,4"/>
                            <Button Content="⊞  All Games"
                                    Style="{StaticResource SidebarItemStyle}"
                                    Click="NavAllGames_Click"/>
                            <Button Content="🕐  Recently Added"
                                    Style="{StaticResource SidebarItemStyle}"
                                    Click="NavRecentlyAdded_Click"/>
                            <!-- User-created collections injected here at runtime -->
                            <StackPanel x:Name="UserCollectionsPanel"/>

                            <!-- Options -->
                            <TextBlock Text="OPTIONS"
                                       Style="{StaticResource LabelMuted}"
                                       Margin="16,4,0,4"/>
                            <Button Content="⚙  Preferences"
                                    Style="{StaticResource SidebarItemStyle}"
                                    Click="NavPreferences_Click"/>
                            <Button Content="↓  Import ROMs"
                                    Style="{StaticResource SidebarItemStyle}"
                                    Click="NavImport_Click"/>

                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- ── CONTENT AREA ── -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="44"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Toolbar -->
                    <Border Grid.Row="0"
                            Background="{StaticResource BgSecondaryBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}"
                            BorderThickness="0,1,0,1">
                        <!-- Three-column grid: Auto | * | Auto guarantees true centering of the nav buttons -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- LEFT: grid/list view toggle -->
                            <Border Grid.Column="0"
                                    Background="#1E1E1E"
                                    CornerRadius="10"
                                    BorderThickness="0"
                                    VerticalAlignment="Center"
                                    Margin="12,0,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <ToggleButton x:Name="ViewGrid"
                                                  Style="{StaticResource ViewGridStyle}"
                                                  IsChecked="True"
                                                  Click="ViewToggle_Click"
                                                  Tag="Grid"/>
                                    <ToggleButton x:Name="ViewList"
                                                  Style="{StaticResource ViewListStyle}"
                                                  Click="ViewToggle_Click"
                                                  Tag="List"/>
                                </StackPanel>
                            </Border>

                            <!-- CENTER: Library / Save States nav, truly centered -->
                            <Border Grid.Column="1"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Background="#1E1E1E"
                                    CornerRadius="10"
                                    BorderThickness="0">
                                <StackPanel Orientation="Horizontal">
                                    <ToggleButton x:Name="TabLibrary"
                                                  Content="Library"
                                                  Style="{StaticResource TabToggleLeftStyle}"
                                                  Click="Tab_Click"
                                                  Tag="Library"/>
                                    <ToggleButton x:Name="TabSaveStates"
                                                  Content="Save States"
                                                  Style="{StaticResource TabToggleMiddleStyle}"
                                                  Click="Tab_Click"
                                                  Tag="SaveStates"/>
                                    <ToggleButton x:Name="TabScreenshots"
                                                  Content="Screenshots"
                                                  Style="{StaticResource TabToggleRightStyle}"
                                                  Click="Tab_Click"
                                                  Tag="Screenshots"/>
                                </StackPanel>
                            </Border>

                            <!-- RIGHT: search bar -->
                            <Border Grid.Column="2"
                                    Background="{StaticResource BgTertiaryBrush}"
                                    BorderBrush="{StaticResource BorderSubtleBrush}"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Padding="10,0"
                                    Width="180"
                                    Height="26"
                                    VerticalAlignment="Center"
                                    Margin="0,0,12,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="⌕"
                                               FontSize="13"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,6,0"/>
                                    <TextBox Grid.Column="1"
                                             x:Name="SearchBox"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Foreground="{StaticResource TextPrimaryBrush}"
                                             CaretBrush="{StaticResource AccentBrush}"
                                             FontFamily="{StaticResource PrimaryFont}"
                                             FontSize="12"
                                             VerticalAlignment="Center"
                                             TextChanged="SearchBox_TextChanged">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox">
                                                <Style.Triggers>
                                                    <Trigger Property="Text" Value="">
                                                        <Setter Property="Background">
                                                            <Setter.Value>
                                                                <VisualBrush Stretch="None" AlignmentX="Left">
                                                                    <VisualBrush.Visual>
                                                                        <TextBlock Text="Search games…"
                                                                                   Foreground="{StaticResource TextMutedBrush}"
                                                                                   FontFamily="{StaticResource PrimaryFont}"
                                                                                   FontSize="12"/>
                                                                    </VisualBrush.Visual>
                                                                </VisualBrush>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                </Grid>
                            </Border>

                            <!-- Hidden; kept for code-behind compat (artwork fetch status, etc.) -->
                            <TextBlock x:Name="ToolbarTitle" Visibility="Collapsed"/>
                        </Grid>
                    </Border>

                    <!-- Game grid (Library view) -->
                    <Grid x:Name="GameContentGrid" Grid.Row="1">

                    <!-- ── Flat grid: virtualized ListBox + VirtualizingWrapPanel ─────────────── -->
                    <!-- Only ~60 card visuals exist at any time regardless of library size.       -->
                    <ListBox x:Name="GameGridView"
                             ItemsSource="{Binding Games}"
                             Visibility="{Binding IsGroupedView, Converter={StaticResource InverseBoolToVisibility}}"
                             SelectionMode="Extended"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling"
                             VirtualizingPanel.ScrollUnit="Item"
                             VirtualizingPanel.CacheLengthUnit="Page"
                             VirtualizingPanel.CacheLength="0.5,0.5"
                             ScrollViewer.CanContentScroll="True"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             Background="Transparent"
                             BorderThickness="0"
                             Margin="{DynamicResource LibraryGridPadding}"
                             PreviewMouseWheel="GameGridView_PreviewMouseWheel">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Grid>
                                                <ContentPresenter/>
                                                <!-- Selection ring overlay -->
                                                <Border x:Name="SelectionRing"
                                                        CornerRadius="8"
                                                        BorderThickness="2"
                                                        BorderBrush="#E03535"
                                                        Visibility="Collapsed"
                                                        IsHitTestVisible="False"/>
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="SelectionRing" Property="Visibility" Value="Visible"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <vwp:VirtualizingWrapPanel/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Width="{DynamicResource LibraryCardWidth}"
                                        Margin="{DynamicResource LibraryCardMargin}"
                                        CornerRadius="8"
                                        ClipToBounds="True"
                                        Background="Transparent"
                                        Cursor="Hand"
                                        MouseLeftButtonDown="GameCard_Click"
                                        MouseRightButtonUp="GameCard_RightClick">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Effect">
                                                        <Setter.Value>
                                                            <DropShadowEffect BlurRadius="16"
                                                                              ShadowDepth="4"
                                                                              Opacity="0.5"
                                                                              Color="#000000"/>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <Border Background="Transparent"
                                                ClipToBounds="True">
                                            <Border.Height>
                                                <MultiBinding Converter="{StaticResource ConsoleToArtHeight}">
                                                    <Binding Path="Console"/>
                                                    <Binding Source="{StaticResource CardWidthProxy}" Path="Data"/>
                                                </MultiBinding>
                                            </Border.Height>
                                            <Grid>
                                                <Border Visibility="{Binding CoverArtPath, Converter={StaticResource NullToVisibility}}">
                                                    <Border.Background>
                                                        <SolidColorBrush Color="{Binding BackgroundColor, Converter={StaticResource StringToColor}}"/>
                                                    </Border.Background>
                                                </Border>
                                                <Border Visibility="{Binding CoverArtPath, Converter={StaticResource NullToVisibility}}">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                            <GradientStop Color="#33FFFFFF" Offset="0"/>
                                                            <GradientStop Color="#00FFFFFF" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                </Border>
                                                <TextBlock Text="{Binding Title}"
                                                           FontFamily="{StaticResource PrimaryFont}"
                                                           FontSize="13" FontWeight="SemiBold"
                                                           Foreground="#CCFFFFFF"
                                                           TextWrapping="Wrap" TextAlignment="Center"
                                                           VerticalAlignment="Center" HorizontalAlignment="Center"
                                                           Margin="12"
                                                           Visibility="{Binding CoverArtPath, Converter={StaticResource NullToVisibility}}"/>
                                                <Image Source="{Binding CoverArtPath, Converter={StaticResource PathToImage}}"
                                                       Stretch="Uniform"
                                                       Visibility="{Binding CoverArtPath, Converter={StaticResource NotNullToVisibility}}"/>
                                                <TextBlock Text="♥" FontSize="14" Foreground="#FFFF6B6B"
                                                           VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,8,8,0"
                                                           Visibility="{Binding IsFavorite, Converter={StaticResource BoolToVisibility}}"/>
                                            </Grid>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- ── Grouped / list views: per-console sections + list view ── -->
                    <ScrollViewer x:Name="LibraryView"
                                  Visibility="{Binding IsGroupedView, Converter={StaticResource BoolToVisibility}}"
                                  VerticalScrollBarVisibility="Auto"
                                  PreviewMouseWheel="LibraryView_PreviewMouseWheel">
                        <StackPanel Margin="{DynamicResource LibraryGridPadding}">

                            <!-- Game grid grouped (All Games view — one section per console) -->
                            <ItemsControl x:Name="GameGridGroupedView"
                                          ItemsSource="{Binding GroupedGames}"
                                          Visibility="{Binding IsGroupedView, Converter={StaticResource BoolToVisibility}}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,0,0,24">
                                            <!-- Console section header with total count -->
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                <TextBlock Style="{StaticResource LabelMuted}">
                                                    <Run Text="{Binding ConsoleName}"/>
                                                    <Run Text=" "/>
                                                    <Run Text="{Binding TotalCount, StringFormat='({0})'}" Foreground="#666"/>
                                                </TextBlock>
                                                <TextBlock Margin="12,0,0,0"
                                                           Cursor="Hand"
                                                           Foreground="#E03535"
                                                           FontSize="11"
                                                           VerticalAlignment="Center"
                                                           Tag="{Binding ConsoleName}"
                                                           MouseLeftButtonDown="GroupSeeAll_Click"
                                                           Visibility="{Binding HasMore, Converter={StaticResource BoolToVisibility}}">
                                                    <Run Text="{Binding MoreText}"/>
                                                </TextBlock>
                                            </StackPanel>
                                            <!-- Games preview (up to 8 per console) -->
                                            <ItemsControl ItemsSource="{Binding Games}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Width="148"
                                                                Margin="0,0,12,12"
                                                                CornerRadius="8"
                                                                ClipToBounds="True"
                                                                Background="Transparent"
                                                                Cursor="Hand"
                                                                MouseLeftButtonDown="GameCard_Click"
                                                                MouseRightButtonUp="GameCard_RightClick">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Style.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter Property="Effect">
                                                                                <Setter.Value>
                                                                                    <DropShadowEffect BlurRadius="16" ShadowDepth="4" Opacity="0.5" Color="#000000"/>
                                                                                </Setter.Value>
                                                                            </Setter>
                                                                        </Trigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <StackPanel>
                                                                <Border Background="Transparent"
                                                                        ClipToBounds="True">
                                                                    <Border.Height>
                                                                        <MultiBinding Converter="{StaticResource ConsoleToArtHeight}">
                                                                            <Binding Path="Console"/>
                                                                            <Binding Source="{StaticResource CardWidthProxy}" Path="Data"/>
                                                                        </MultiBinding>
                                                                    </Border.Height>
                                                                    <Grid>
                                                                        <Border Visibility="{Binding CoverArtPath, Converter={StaticResource NullToVisibility}}">
                                                                            <Border.Background>
                                                                                <SolidColorBrush Color="{Binding BackgroundColor, Converter={StaticResource StringToColor}}"/>
                                                                            </Border.Background>
                                                                        </Border>
                                                                        <Border Visibility="{Binding CoverArtPath, Converter={StaticResource NullToVisibility}}">
                                                                            <Border.Background>
                                                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                                                    <GradientStop Color="#33FFFFFF" Offset="0"/>
                                                                                    <GradientStop Color="#00FFFFFF" Offset="1"/>
                                                                                </LinearGradientBrush>
                                                                            </Border.Background>
                                                                        </Border>
                                                                        <TextBlock Text="{Binding Title}"
                                                                                   FontFamily="{StaticResource PrimaryFont}"
                                                                                   FontSize="13" FontWeight="SemiBold"
                                                                                   Foreground="#CCFFFFFF"
                                                                                   TextWrapping="Wrap" TextAlignment="Center"
                                                                                   VerticalAlignment="Center" HorizontalAlignment="Center"
                                                                                   Margin="12"
                                                                                   Visibility="{Binding CoverArtPath, Converter={StaticResource NullToVisibility}}"/>
                                                                        <Image Source="{Binding CoverArtPath, Converter={StaticResource PathToImage}}"
                                                                               Stretch="Uniform"
                                                                               Visibility="{Binding CoverArtPath, Converter={StaticResource NotNullToVisibility}}"/>
                                                                        <TextBlock Text="♥" FontSize="14" Foreground="#FFFF6B6B"
                                                                                   VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,8,8,0"
                                                                                   Visibility="{Binding IsFavorite, Converter={StaticResource BoolToVisibility}}"/>
                                                                    </Grid>
                                                                </Border>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </StackPanel>
                    </ScrollViewer>

                    <!-- Game list (list view) — sibling of LibraryView, NOT inside it.
                         Uses a virtualized ListBox so large libraries don't stall on first render. -->
                    <ListBox x:Name="GameListView"
                             ItemsSource="{Binding Games}"
                             Visibility="Collapsed"
                             SelectionMode="Extended"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling"
                             VirtualizingPanel.ScrollUnit="Item"
                             ScrollViewer.CanContentScroll="True"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="{DynamicResource LibraryGridPadding}"
                             PreviewMouseWheel="GameListView_PreviewMouseWheel">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <ContentPresenter/>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8,6"
                                        Cursor="Hand"
                                        MouseLeftButtonDown="GameCard_Click"
                                        MouseRightButtonUp="GameCard_RightClick">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource BgTertiaryBrush}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="48"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <!-- Thumbnail: colored background only when no cover art (same as grid view) -->
                                        <Border Grid.Column="0"
                                                Width="44" Height="44"
                                                CornerRadius="4"
                                                ClipToBounds="True">
                                            <Grid>
                                                <Border Visibility="{Binding CoverArtPath, Converter={StaticResource NullToVisibility}}">
                                                    <Border.Background>
                                                        <SolidColorBrush Color="{Binding BackgroundColor, Converter={StaticResource StringToColor}}"/>
                                                    </Border.Background>
                                                </Border>
                                                <Image Source="{Binding CoverArtPath, Converter={StaticResource PathToImage}}"
                                                       Stretch="UniformToFill"
                                                       Visibility="{Binding CoverArtPath, Converter={StaticResource NotNullToVisibility}}"/>
                                            </Grid>
                                        </Border>
                                        <StackPanel Grid.Column="1"
                                                    VerticalAlignment="Center"
                                                    Margin="10,0,0,0">
                                            <TextBlock Text="{Binding Title}"
                                                       FontFamily="{StaticResource PrimaryFont}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <TextBlock Text="{Binding Console}"
                                                       FontFamily="{StaticResource PrimaryFont}"
                                                       FontSize="11"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Empty state — sits above both views, visible only when library is empty -->
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Visibility="{Binding Games.Count,
                                    Converter={StaticResource CountToVisibility}}">
                        <TextBlock Text="🕹"
                                   FontSize="48"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="No games here yet"
                                   FontFamily="{StaticResource PrimaryFont}"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,12,0,0"/>
                        <TextBlock Text="Drop ROM files anywhere to import them"
                                   FontFamily="{StaticResource PrimaryFont}"
                                   FontSize="13"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,6,0,0"/>
                    </StackPanel>

                    </Grid>

                    <!-- Screenshots view -->
                    <ScrollViewer x:Name="ScreenshotsView"
                                  Grid.Row="1"
                                  Visibility="Collapsed"
                                  Style="{StaticResource MinimalScrollViewer}"
                                  VerticalScrollBarVisibility="Auto"
                                  Padding="16">
                        <StackPanel>
                            <!-- Empty state -->
                            <StackPanel x:Name="ScreenshotsEmptyState"
                                        HorizontalAlignment="Center"
                                        Margin="0,60,0,0"
                                        Visibility="Collapsed">
                                <TextBlock Text="📷"
                                           FontSize="48"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,12"/>
                                <TextBlock Text="Screenshots will appear here when they've been saved."
                                           FontFamily="{StaticResource PrimaryFont}"
                                           FontSize="13"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="To take a screenshot, press Print Screen or F12 while in a game."
                                           FontFamily="{StaticResource PrimaryFont}"
                                           FontSize="12"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           HorizontalAlignment="Center"
                                           Opacity="0.6"
                                           Margin="0,6,0,0"/>
                            </StackPanel>
                            <!-- Grid of screenshot cards -->
                            <WrapPanel x:Name="ScreenshotsPanel"
                                       Orientation="Horizontal"/>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Save States view -->
                    <ScrollViewer x:Name="SaveStatesView"
                                  Grid.Row="1"
                                  Visibility="Collapsed"
                                  Style="{StaticResource MinimalScrollViewer}"
                                  VerticalScrollBarVisibility="Auto"
                                  Padding="16">
                        <StackPanel>
                            <TextBlock x:Name="SaveStatesEmptyText"
                                       Text="No save states yet. Press F5 or the Save State button while in a game."
                                       FontFamily="{StaticResource PrimaryFont}"
                                       FontSize="13"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       HorizontalAlignment="Center"
                                       Margin="0,60,0,0"
                                       Visibility="Collapsed"/>
                            <StackPanel x:Name="SaveStatesPanel"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

            </Grid>

            <!-- ── DROP OVERLAY ── -->
            <Border x:Name="DropOverlay"
                    Grid.RowSpan="2"
                    Visibility="Collapsed"
                    Background="#CC0F0F10"
                    CornerRadius="10">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <Border Width="160" Height="160"
                            BorderBrush="{StaticResource AccentBrush}"
                            BorderThickness="2"
                            CornerRadius="80">
                        <TextBlock Text="🕹"
